  <data key="d7">3.0</data>
  <data key="d8">The Consumer initiates the process by notifying the Economic Operator of Contract Termination.&lt;SEP&gt;The Consumer initiates contract termination by notifying the Economic Operator, triggering subsequent obligations.&lt;SEP&gt;The Consumer can exercise Contract Termination as a remedy for harm suffered.</data>
  <data key="d9">action,initiation,legal action,notification,notification trigger,remedy</data>
  <data key="d10">chunk-93b8a69d3470d8fd4caae59080df0a54&lt;SEP&gt;chunk-019c5b0704e7195269616af2f7e331e2&lt;SEP&gt;chunk-e2e9d4353bb95f7bca809f541cd54320</data>
  <data key="d11">مشروع_نظام_حماية_المستهلك</data>
  <data key="d12">1776814304</data>
  <data key="d13"></data>
</edge>
<edge source="Consumer" target="Systematic Warranty">
  <data key="d7">1.0</data>
  <data key="d8">The Consumer's use of the Product is restricted to what is necessary to verify the Systematic Warranty defined in Article 49.</data>
  <data key="d9">legal reference,usage scope</data>
  <data key="d10">chunk-93b8a69d3470d8fd4caae59080df0a54</data>
  <data key="d11">مشروع_نظام_حماية_المستهلك</data>
  <data key="d12">1776814068</data>
  <data key="d13"></data>
</edge>
<edge source="Consumer" target="Article 38">
  <data key="d7">1.0</data>
  <data key="d8">Article 38 establishes the rights of the consumer regarding contract termination.</data>
  <data key="d9">legal protection,rights assignment</data>
  <data key="d10">chunk-9ee11e2f2efdecd0a6233d3dde78ac94</data>
  <data key="d11">مشروع_نظام_حماية_المستهلك</data>
  <data key="d12">1776814075</data>
  <data key="d13"></data>
</edge>
<edge source="Consumer" target="Remote Sales Contract">
  <data key="d7">1.0</data>
  <data key="d8">A Consumer is the other primary party involved in a remote sales contract and is granted specific protections.</data>
  <data key="d9">contractual party,protected entity</data>
  <data key="d10">chunk-c47f120917e5636d314c4a5e75774c7a</data>
  <data key="d11">مشروع_نظام_حماية_المستهلك</data>
  <data key="d12">1776814085</data>
  <data key="d13"></data>
</edge>
<edge source="Consumer" target="System Regulations">
  <data key="d7">1.0</data>
  <data key="d8">Consumers are entitled to the protections established by the System Regulations regarding remote contracts.</data>
  <data key="d9">legal protection,rights assignment</data>
  <data key="d10">chunk-c47f120917e5636d314c4a5e75774c7a</data>
  <data key="d11">مشروع_نظام_حماية_المستهلك</data>
  <data key="d12">1776814086</data>
  <data key="d13"></data>
</edge>
<edge source="Consumer" target="Article Thirty-Nine">
  <data key="d7">1.0</data>
  <data key="d8">Article Thirty-Nine explicitly grants consumers the right to protection under the system when entering into remote contracts.</data>
  <data key="d9">legal protection,regulatory scope</data>
  <data key="d10">chunk-c47f120917e5636d314c4a5e75774c7a</data>
  <data key="d11">مشروع_نظام_حماية_المستهلك</data>
  <data key="d12">1776814086</data>
  <data key="d13"></data>
</edge>
<edge source="Consumer" target="Article 41">
  <data key="d7">1.0</data>
  <data key="d8">Article 41 grants the Consumer the right to terminate remote contracts.</data>
  <data key="d9">legal right,protection</data>
  <data key="d10">chunk-301a4ffbdfd6fdb0a956239d0553872e</data>
  <data key="d11">مشروع_نظام_حماية_المستهلك</data>
  <data key="d12">1776814099</data>
  <data key="d13"></data>
</edge>
<edge source="Consumer" target="Burden of Proof">
  <data key="d7">1.0</data>
  <data key="d8">The Consumer bears the Burden of Proof to show that the contract was terminated.</data>
