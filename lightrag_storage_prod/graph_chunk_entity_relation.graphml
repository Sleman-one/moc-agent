  <data key="d11">مشروع_نظام_حماية_المستهلك</data>
  <data key="d12">1776814144</data>
  <data key="d13"></data>
</edge>
<edge source="Economic Operator" target="Digital Content Contracts">
  <data key="d7">1.0</data>
  <data key="d8">The Economic Operator provides digital content or services that may be bundled with products to include them in the warranty.</data>
  <data key="d9">bundling,provider</data>
  <data key="d10">chunk-5086b6cf9bc02c27ea5fb4cb9ed609ed</data>
