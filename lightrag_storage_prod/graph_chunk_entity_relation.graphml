  <data key="d12">1776814369</data>
  <data key="d13"></data>
</edge>
<edge source="Consumer" target="Electronic Platforms For Dispute Resolution">
  <data key="d7">1.0</data>
  <data key="d8">Platforms are required to disclose information about the Consumer's waiver right, and the binding and enforceable nature of results to the Consumer/Public.</data>
  <data key="d9">disclosure,transparency</data>
  <data key="d10">chunk-8eba08bab139116de9ee95fe214a7f7e</data>
  <data key="d11">مشروع_نظام_حماية_المستهلك</data>
  <data key="d12">1776814369</data>
  <data key="d13"></data>
</edge>
<edge source="Consumer" target="Committee For Examining Violations">
  <data key="d7">1.0</data>
  <data key="d8">The Committee warns the Consumer about violations committed by Economic Operators to ensure safety and transparency.</data>
  <data key="d9">protection,warning</data>
  <data key="d10">chunk-51ea5244ed2d72532c1d4e4a8c7c8711</data>
