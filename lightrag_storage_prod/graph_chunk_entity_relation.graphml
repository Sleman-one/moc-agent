</edge>
<edge source="Article Forty" target="Automatic Vending Machines">
  <data key="d7">1.0</data>
  <data key="d8">Contracts made through Automatic Vending Machines are explicitly excluded from the application of off-premises contract rules by Article Forty.</data>
  <data key="d9">exception,transaction method</data>
  <data key="d10">chunk-0931bf17be9284d5fcf4f6332cd19598</data>
  <data key="d11">مشروع_نظام_حماية_المستهلك</data>
  <data key="d12">1776814091</data>
  <data key="d13"></data>
</edge>
<edge source="Article Forty" target="Financial Service Contracts">
  <data key="d7">1.0</data>
  <data key="d8">Contracts providing Financial Services are listed as an exception under Article Forty, meaning off-premises rules do not apply to them.</data>
  <data key="d9">exception,sector-specific exemption</data>
  <data key="d10">chunk-0931bf17be9284d5fcf4f6332cd19598</data>
  <data key="d11">مشروع_نظام_حماية_المستهلك</data>
