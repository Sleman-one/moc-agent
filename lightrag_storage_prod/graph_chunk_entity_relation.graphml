  <data key="d12">1776814144</data>
  <data key="d13"></data>
</edge>
<edge source="Economic Operator" target="Product Or Service">
  <data key="d7">3.0</data>
  <data key="d8">The Economic Operator guarantees that the Product Or Service matches the required standards.&lt;SEP&gt;The Economic Operator provides the Product Or Service that is the subject of the non-compliance report.&lt;SEP&gt;The Economic Operator provides the Product or Service, which must be compliant with warranty requirements at delivery.</data>
  <data key="d9">compliance,provider,provision,responsibility,subject matter</data>
  <data key="d10">chunk-c6572d1610f6bb7f6ec41fc6f8eb934f&lt;SEP&gt;chunk-6d5f73112067d3017eacad446fe05c6c&lt;SEP&gt;chunk-d15616980ad303389944137db1af4f22</data>
  <data key="d11">مشروع_نظام_حماية_المستهلك</data>
  <data key="d12">1776814195</data>
  <data key="d13"></data>
</edge>
<edge source="Economic Operator" target="Standards And Specifications">
  <data key="d7">1.0</data>
  <data key="d8">The Economic Operator ensures conformity with Standards And Specifications.</data>
  <data key="d9">adherence,quality control</data>
  <data key="d10">chunk-c6572d1610f6bb7f6ec41fc6f8eb934f</data>
  <data key="d11">مشروع_نظام_حماية_المستهلك</data>
  <data key="d12">1776814137</data>
  <data key="d13"></data>
</edge>
<edge source="Economic Operator" target="Quality Standards">
  <data key="d7">1.0</data>
  <data key="d8">The Economic Operator is legally obligated under Article Forty-Six to ensure conformity with Quality Standards.</data>
  <data key="d9">compliance,regulatory requirement</data>
  <data key="d10">chunk-c6572d1610f6bb7f6ec41fc6f8eb934f</data>
  <data key="d11">مشروع_نظام_حماية_المستهلك</data>
  <data key="d12">1776814137</data>
  <data key="d13"></data>
</edge>
<edge source="Economic Operator" target="Article Forty-Seven">
  <data key="d7">1.0</data>
  <data key="d8">Article Forty-Seven mandates that the Economic Operator must report non-compliance to the Competent Authority.</data>
  <data key="d9">legal obligation,reporting duty</data>
  <data key="d10">chunk-6d5f73112067d3017eacad446fe05c6c</data>
  <data key="d11">مشروع_نظام_حماية_المستهلك</data>
  <data key="d12">1776814143</data>
  <data key="d13"></data>
</edge>
<edge source="Economic Operator" target="Product Or Service Non-Compliance">
  <data key="d7">1.0</data>
