  <data key="d12">1776814133</data>
  <data key="d13"></data>
</edge>
<edge source="Consumer" target="Implementing Regulations">
  <data key="d7">1.0</data>
  <data key="d8">The Consumer is subject to the methods and procedures for consent confirmation and order modification as defined by the Implementing Regulations.</data>
  <data key="d9">procedural adherence,regulatory compliance</data>
  <data key="d10">chunk-bbcbc9c6d4024ed107a3aed8073f87c9</data>
