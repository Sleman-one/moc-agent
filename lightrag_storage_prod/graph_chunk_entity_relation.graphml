  <data key="d12">1776814099</data>
  <data key="d13"></data>
</edge>
<edge source="Consumer" target="Authorized Representative">
  <data key="d7">1.0</data>
  <data key="d8">The Consumer designates an Authorized Representative to receive the product on their behalf.</data>
