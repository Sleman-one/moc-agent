  <data key="d6"></data>
</node>
<node id="Twenty-Fifth Article">
  <data key="d0">Twenty-Fifth Article</data>
  <data key="d1">content</data>
  <data key="d2">A specific legal article whose violation triggers penalties under Article Ninety-Seven.</data>
  <data key="d3">chunk-0f17c98aec4af855d06847e8dc54f39d</data>
  <data key="d4">مشروع_نظام_حماية_المستهلك</data>
  <data key="d5">1776814438</data>
  <data key="d6"></data>
</node>
<node id="Twenty-Sixth Article">
  <data key="d0">Twenty-Sixth Article</data>
  <data key="d1">content</data>
  <data key="d2">A specific legal article whose violation triggers penalties under Article Ninety-Seven.</data>
  <data key="d3">chunk-0f17c98aec4af855d06847e8dc54f39d</data>
  <data key="d4">مشروع_نظام_حماية_المستهلك</data>
  <data key="d5">1776814438</data>
  <data key="d6"></data>
</node>
<node id="Thirtieth Article">
  <data key="d0">Thirtieth Article</data>
  <data key="d1">content</data>
  <data key="d2">A specific legal article whose violation triggers penalties under Article Ninety-Seven.</data>
  <data key="d3">chunk-0f17c98aec4af855d06847e8dc54f39d</data>
  <data key="d4">مشروع_نظام_حماية_المستهلك</data>
  <data key="d5">1776814438</data>
  <data key="d6"></data>
</node>
<node id="Forty-Seventh Article">
  <data key="d0">Forty-Seventh Article</data>
  <data key="d1">content</data>
  <data key="d2">A specific legal article whose violation triggers penalties under Article Ninety-Seven.</data>
  <data key="d3">chunk-0f17c98aec4af855d06847e8dc54f39d</data>
  <data key="d4">مشروع_نظام_حماية_المستهلك</data>
  <data key="d5">1776814438</data>
  <data key="d6"></data>
</node>
<node id="Sixty-Third Article Clause 3">
  <data key="d0">Sixty-Third Article Clause 3</data>
  <data key="d1">content</data>
  <data key="d2">A specific clause within the Sixth-Tieth Article related to judicial orders for stopping non-compliant practices, violation of which incurs penalties.</data>
  <data key="d3">chunk-0f17c98aec4af855d06847e8dc54f39d</data>
  <data key="d4">مشروع_نظام_حماية_المستهلك</data>
  <data key="d5">1776814439</data>
  <data key="d6"></data>
</node>
<node id="Seventy-Seventh Article">
  <data key="d0">Seventy-Seventh Article</data>
  <data key="d1">content</data>
  <data key="d2">An article that establishes corrective measures; failure to comply with these measures incurs penalties under Article Ninety-Seven.</data>
  <data key="d3">chunk-0f17c98aec4af855d06847e8dc54f39d</data>
  <data key="d4">مشروع_نظام_حماية_المستهلك</data>
  <data key="d5">1776814439</data>
  <data key="d6"></data>
</node>
<node id="Judicial Orders And Rulings">
  <data key="d0">Judicial Orders And Rulings</data>
  <data key="d1">concept</data>
  <data key="d2">Official directives issued by the competent court to stop or prevent non-compliant practices, as per Sixty-Third Article Clause 3.</data>
  <data key="d3">chunk-0f17c98aec4af855d06847e8dc54f39d</data>
  <data key="d4">مشروع_نظام_حماية_المستهلك</data>
  <data key="d5">1776814439</data>
  <data key="d6"></data>
</node>
<node id="Public Prosecution">
  <data key="d0">Public Prosecution</data>
  <data key="d1">organization</data>
  <data key="d2">The legal authority responsible for investigating and prosecuting offenses defined in Article Ninety-Seven.</data>
  <data key="d3">chunk-0f17c98aec4af855d06847e8dc54f39d</data>
  <data key="d4">مشروع_نظام_حماية_المستهلك</data>
  <data key="d5">1776814439</data>
  <data key="d6"></data>
</node>
<node id="Criminal Penalties">
  <data key="d0">Criminal Penalties</data>
  <data key="d1">concept</data>
  <data key="d2">Criminal penalties refer to the legal sanctions, including fines and potential imprisonment, prescribed for violations of specific articles within the law.</data>
  <data key="d3">chunk-0f17c98aec4af855d06847e8dc54f39d</data>
  <data key="d4">مشروع_نظام_حماية_المستهلك</data>
  <data key="d5">1776814439</data>
  <data key="d6"></data>
</node>
<node id="Article 80">
  <data key="d0">Article 80</data>
  <data key="d1">content</data>
  <data key="d2">Article 80 is a legal provision titled "Reconciling Situations" that mandates economic operators and others subject to the regulation to align their status with its provisions within one year of its enforcement.</data>
  <data key="d3">chunk-4fe0038af572654f7ea64ab35fd3849a</data>
  <data key="d4">مشروع_نظام_حماية_المستهلك</data>
  <data key="d5">1776814444</data>
  <data key="d6"></data>
</node>
<node id="Reconciling Situations">
  <data key="d0">Reconciling Situations</data>
  <data key="d1">concept</data>
  <data key="d2">Reconciling Situations is the title and core concept of Article 80, referring to the process of aligning legal or operational status with regulatory requirements.</data>
  <data key="d3">chunk-4fe0038af572654f7ea64ab35fd3849a</data>
  <data key="d4">مشروع_نظام_حماية_المستهلك</data>
  <data key="d5">1776814444</data>
  <data key="d6"></data>
</node>
<node id="Article Eighty-One">
  <data key="d0">Article Eighty-One</data>
  <data key="d1">content</data>
  <data key="d2">Article Eighty-One is a specific legal provision titled "The Regulation" within a regulatory system.</data>
  <data key="d3">chunk-53d255606873f798c277f71c669581e4</data>
  <data key="d4">مشروع_نظام_حماية_المستهلك</data>
  <data key="d5">1776814451</data>
  <data key="d6"></data>
</node>
<node id="The Regulation">
  <data key="d0">The Regulation</data>
  <data key="d1">content</data>
  <data key="d2">The Regulation is the official document issued under Article Eighty-One, which becomes effective upon its enforcement.</data>
  <data key="d3">chunk-53d255606873f798c277f71c669581e4</data>
  <data key="d4">مشروع_نظام_حماية_المستهلك</data>
  <data key="d5">1776814451</data>
  <data key="d6"></data>
</node>
<node id="Official Gazette">
  <data key="d0">Official Gazette</data>
  <data key="d1">location</data>
  <data key="d2">The Official Gazette is the publication where the system was published, marking the starting point for the timeline to issue the regulation.&lt;SEP&gt;The Official Gazette is the publication where the new system must be published before it enters into force.&lt;SEP&gt;The Official Gazette is the publication where the System was published, serving as the reference date for timelines.&lt;SEP&gt;The Official Gazette is the publication where the regulation was published, marking the start date for the waiting period.</data>
  <data key="d3">chunk-53d255606873f798c277f71c669581e4&lt;SEP&gt;chunk-a3b69865f5086a21397426b8108eefe1&lt;SEP&gt;chunk-3323a5605fc02cf6b08e6daf15866451&lt;SEP&gt;chunk-f1cdab301d132fa946f551f1fb83be2d</data>
  <data key="d4">مشروع_نظام_حماية_المستهلك&lt;SEP&gt;نظام_التجارة_الإلكترونية</data>
  <data key="d5">1776814646</data>
  <data key="d6"></data>
</node>
<node id="180-Day Period">
  <data key="d0">180-Day Period</data>
  <data key="d1">concept</data>
  <data key="d2">The 180-Day Period is the statutory timeframe allowed for the Head of the Competent Authority to issue the regulation after the System's publication.</data>
  <data key="d3">chunk-53d255606873f798c277f71c669581e4</data>
  <data key="d4">مشروع_نظام_حماية_المستهلك</data>
  <data key="d5">1776814451</data>
  <data key="d6"></data>
</node>
<node id="Enforcement Date">
  <data key="d0">Enforcement Date</data>
  <data key="d1">concept</data>
  <data key="d2">The Enforcement Date is the specific date when the regulation becomes legally effective.</data>
  <data key="d3">chunk-53d255606873f798c277f71c669581e4</data>
  <data key="d4">مشروع_نظام_حماية_المستهلك</data>
  <data key="d5">1776814451</data>
  <data key="d6"></data>
</node>
<node id="Article Eighty-Two">
  <data key="d0">Article Eighty-Two</data>
  <data key="d1">content</data>
  <data key="d2">Article Eighty-Two, titled "Entry into Force," specifies the repeal of previous regulations and sets the effective date for the current system.</data>
  <data key="d3">chunk-a3b69865f5086a21397426b8108eefe1</data>
  <data key="d4">مشروع_نظام_حماية_المستهلك</data>
  <data key="d5">1776814458</data>
  <data key="d6"></data>
</node>
<node id="Anti-Commercial Fraud System">
  <data key="d0">Anti-Commercial Fraud System</data>
  <data key="d1">concept</data>
  <data key="d2">The Anti-Commercial Fraud System is a previous regulation repealed by the current system, issued via Royal Decree No. (M/19) on 23/4/1429 AH.</data>
  <data key="d3">chunk-a3b69865f5086a21397426b8108eefe1</data>
  <data key="d4">مشروع_نظام_حماية_المستهلك</data>
  <data key="d5">1776814458</data>
  <data key="d6"></data>
</node>
<node id="Electronic Commerce System">
  <data key="d0">Electronic Commerce System</data>
  <data key="d1">concept</data>
  <data key="d2">The Electronic Commerce System is a previous regulation repealed by the current system, issued via Royal Decree No. (M/126) on 7/11/1440 AH.</data>
  <data key="d3">chunk-a3b69865f5086a21397426b8108eefe1</data>
  <data key="d4">مشروع_نظام_حماية_المستهلك</data>
  <data key="d5">1776814458</data>
  <data key="d6"></data>
</node>
<node id="Royal Decree No. M/19">
  <data key="d0">Royal Decree No. M/19</data>
  <data key="d1">artifact</data>
  <data key="d2">Royal Decree No. (M/19) is the legal instrument that issued the Anti-Commercial Fraud System on 23/4/1429 AH.</data>
  <data key="d3">chunk-a3b69865f5086a21397426b8108eefe1</data>
  <data key="d4">مشروع_نظام_حماية_المستهلك</data>
  <data key="d5">1776814458</data>
  <data key="d6"></data>
</node>
<node id="Royal Decree No. M/126">
  <data key="d0">Royal Decree No. M/126</data>
  <data key="d1">artifact</data>
  <data key="d2">Royal Decree No. (M/126) is the legal instrument that issued the Electronic Commerce System on 7/11/1440 AH.</data>
  <data key="d3">chunk-a3b69865f5086a21397426b8108eefe1</data>
  <data key="d4">مشروع_نظام_حماية_المستهلك</data>
  <data key="d5">1776814458</data>
  <data key="d6"></data>
</node>
<node id="Eighteen Months Period">
  <data key="d0">Eighteen Months Period</data>
  <data key="d1">concept</data>
  <data key="d2">The period of one hundred and eighty days following publication in the Official Gazette required before the system becomes effective.</data>
  <data key="d3">chunk-a3b69865f5086a21397426b8108eefe1</data>
  <data key="d4">مشروع_نظام_حماية_المستهلك</data>
  <data key="d5">1776814458</data>
  <data key="d6"></data>
</node>
<node id="Current System">
  <data key="d0">Current System</data>
  <data key="d1">concept</data>
  <data key="d2">The current regulatory system whose entry into force is defined by Article Eighty-Two, replacing previous anti-fraud and e-commerce regulations.</data>
  <data key="d3">chunk-a3b69865f5086a21397426b8108eefe1</data>
  <data key="d4">مشروع_نظام_حماية_المستهلك</data>
  <data key="d5">1776814458</data>
  <data key="d6"></data>
</node>
<node id="E-Commerce System">
  <data key="d0">E-Commerce System</data>
  <data key="d1">concept</data>
  <data key="d2">The E-Commerce System is the primary legal framework defined in Article 1, establishing terms and definitions for electronic commerce activities.</data>
  <data key="d3">chunk-fc0c7efa3b63af90af17dc69c2eb4ab7</data>
  <data key="d4">نظام_التجارة_الإلكترونية</data>
  <data key="d5">1776814477</data>
  <data key="d6"></data>
</node>
<node id="Executive Regulation">
  <data key="d0">Executive Regulation</data>
  <data key="d1">content</data>
  <data key="d2">The Executive Regulation serves as the supplementary legal document implementing the provisions of the E-Commerce System.</data>
  <data key="d3">chunk-fc0c7efa3b63af90af17dc69c2eb4ab7</data>
  <data key="d4">نظام_التجارة_الإلكترونية</data>
  <data key="d5">1776814477</data>
  <data key="d6"></data>
</node>
<node id="Ministry of Commerce and Investment">
  <data key="d0">Ministry of Commerce and Investment</data>
  <data key="d1">organization</data>
  <data key="d2">The Ministry of Commerce and Investment is the government body responsible for oversight, licensing of verification entities, and general administration of the system.</data>
  <data key="d3">chunk-fc0c7efa3b63af90af17dc69c2eb4ab7</data>
  <data key="d4">نظام_التجارة_الإلكترونية</data>
  <data key="d5">1776814477</data>
  <data key="d6"></data>
</node>
<node id="Minister of Commerce and Investment">
  <data key="d0">Minister of Commerce and Investment</data>
  <data key="d1">person</data>
  <data key="d2">The Minister holds the leadership role within the Ministry of Commerce and Investment and is a defined entity within the regulatory context.</data>
  <data key="d3">chunk-fc0c7efa3b63af90af17dc69c2eb4ab7</data>
  <data key="d4">نظام_التجارة_الإلكترونية</data>
  <data key="d5">1776814477</data>
  <data key="d6"></data>
</node>
<node id="Electronic Commerce">
  <data key="d0">Electronic Commerce</data>
  <data key="d1">concept</data>
  <data key="d2">Electronic Commerce is defined as an economic activity conducted via electronic means by service providers and consumers to sell products, provide services, advertise, or exchange data.</data>
  <data key="d3">chunk-fc0c7efa3b63af90af17dc69c2eb4ab7</data>
  <data key="d4">نظام_التجارة_الإلكترونية</data>
  <data key="d5">1776814477</data>
  <data key="d6"></data>
</node>
<node id="Data">
  <data key="d0">Data</data>
  <data key="d1">data</data>
  <data key="d2">Data refers to any statement regardless of source or form, used directly or indirectly in electronic commerce transactions.</data>
  <data key="d3">chunk-fc0c7efa3b63af90af17dc69c2eb4ab7</data>
  <data key="d4">نظام_التجارة_الإلكترونية</data>
  <data key="d5">1776814477</data>
  <data key="d6"></data>
</node>
<node id="Person">
  <data key="d0">Person</data>
  <data key="d1">person</data>
  <data key="d2">A person is defined as either a natural individual or a legal entity (such as a corporation) recognized under the system.</data>
  <data key="d3">chunk-fc0c7efa3b63af90af17dc69c2eb4ab7</data>
  <data key="d4">نظام_التجارة_الإلكترونية</data>
  <data key="d5">1776814477</data>
  <data key="d6"></data>
</node>
<node id="Merchant">
  <data key="d0">Merchant</data>
  <data key="d1">person</data>
  <data key="d2">A merchant is a person registered in the commercial registry who conducts electronic commerce activities.&lt;SEP&gt;A Merchant is a type of service provider whose place of business is determined by the address specified in their commercial register.</data>
  <data key="d3">chunk-fc0c7efa3b63af90af17dc69c2eb4ab7&lt;SEP&gt;chunk-7b813a98432e97bd821133a34c3ab82c</data>
  <data key="d4">نظام_التجارة_الإلكترونية</data>
  <data key="d5">1776814494</data>
  <data key="d6"></data>
</node>
<node id="Practitioner">
  <data key="d0">Practitioner</data>
  <data key="d1">person</data>
  <data key="d2">A practitioner is a person not registered in the commercial registry who nonetheless engages in electronic commerce activities.&lt;SEP&gt;A Practitioner is a type of service provider whose place of business is typically determined by their electronic office, or their habitual residence if they are a natural person without such an office.</data>
  <data key="d3">chunk-fc0c7efa3b63af90af17dc69c2eb4ab7&lt;SEP&gt;chunk-7b813a98432e97bd821133a34c3ab82c</data>
  <data key="d4">نظام_التجارة_الإلكترونية</data>
  <data key="d5">1776814494</data>
  <data key="d6"></data>
</node>
<node id="Electronic Location">
  <data key="d0">Electronic Location</data>
  <data key="d1">location</data>
  <data key="d2">An electronic location is an online platform enabling service providers to display, sell, or advertise products/services and exchange related data.&lt;SEP&gt;The Electronic Location refers to the website or digital platform where the Service Provider must display the mandated information.</data>
  <data key="d3">chunk-fc0c7efa3b63af90af17dc69c2eb4ab7&lt;SEP&gt;chunk-a02c96de615b73a0b4a82ae7b14bc537</data>
  <data key="d4">نظام_التجارة_الإلكترونية</data>
  <data key="d5">1776814513</data>
  <data key="d6"></data>
</node>
<node id="Electronic Location Verification Entities">
  <data key="d0">Electronic Location Verification Entities</data>
  <data key="d1">organization</data>
  <data key="d2">These are authorized bodies licensed by the Ministry to perform verification processes for electronic locations.</data>
  <data key="d3">chunk-fc0c7efa3b63af90af17dc69c2eb4ab7</data>
  <data key="d4">نظام_التجارة_الإلكترونية</data>
  <data key="d5">1776814478</data>
  <data key="d6"></data>
</node>
<node id="Electronic Correspondence">
  <data key="d0">Electronic Correspondence</data>
  <data key="d1">data</data>
  <data key="d2">Electronic correspondence includes statements, notices, requests, or offers directed by contracting parties via electronic means during negotiation or execution of a contract.&lt;SEP&gt;Electronic correspondence refers to digital messages sent by the consumer where errors may occur.</data>
  <data key="d3">chunk-fc0c7efa3b63af90af17dc69c2eb4ab7&lt;SEP&gt;chunk-ef5c3f67882b7588927d8bca42047269</data>
  <data key="d4">نظام_التجارة_الإلكترونية</data>
  <data key="d5">1776814500</data>
  <data key="d6"></data>
</node>
<node id="Electronic Advertisement">
  <data key="d0">Electronic Advertisement</data>
  <data key="d1">content</data>
  <data key="d2">Electronic advertisement is any publicity by a service provider using electronic means to encourage the direct or indirect sale of a product or service.&lt;SEP&gt;Electronic Advertisement is the medium regulated by Article Eleven, which must not contain prohibited false or misleading statements.</data>
  <data key="d3">chunk-fc0c7efa3b63af90af17dc69c2eb4ab7&lt;SEP&gt;chunk-7dce39ad69ab952b0a24c9573b89731d</data>
  <data key="d4">نظام_التجارة_الإلكترونية</data>
  <data key="d5">1776814549</data>
  <data key="d6"></data>
</node>
<node id="Electronic Means">
  <data key="d0">Electronic Means</data>
  <data key="d1">method</data>
  <data key="d2">Electronic means refers to any technology utilizing electrical, electromagnetic, optical, light, digital, or similar communication and information technologies.</data>
  <data key="d3">chunk-fc0c7efa3b63af90af17dc69c2eb4ab7</data>
  <data key="d4">نظام_التجارة_الإلكترونية</data>
  <data key="d5">1776814478</data>
  <data key="d6"></data>
</node>
<node id="Service Provider Within The Kingdom">
  <data key="d0">Service Provider Within The Kingdom</data>
  <data key="d1">person</data>
  <data key="d2">A service provider located inside the Kingdom who is subject to the regulations of the system.</data>
  <data key="d3">chunk-9b912e56726cb9e0d5237d61584a5fa6</data>
  <data key="d4">نظام_التجارة_الإلكترونية</data>
  <data key="d5">1776814484</data>
  <data key="d6"></data>
</node>
<node id="Practitioner Outside The Kingdom">
  <data key="d0">Practitioner Outside The Kingdom</data>
  <data key="d1">person</data>
  <data key="d2">A practitioner located outside the Kingdom who offers products or services within the Kingdom, accessible to consumers, and is therefore subject to the system's provisions.</data>
  <data key="d3">chunk-9b912e56726cb9e0d5237d61584a5fa6</data>
  <data key="d4">نظام_التجارة_الإلكترونية</data>
  <data key="d5">1776814484</data>
  <data key="d6"></data>
</node>
<node id="Article Three">
  <data key="d0">Article Three</data>
  <data key="d1">content</data>
  <data key="d2">Article Three defines the concept of the service provider's place of business for the application of the system's provisions.</data>
  <data key="d3">chunk-7b813a98432e97bd821133a34c3ab82c</data>
  <data key="d4">نظام_التجارة_الإلكترونية</data>
  <data key="d5">1776814493</data>
  <data key="d6"></data>
</node>
<node id="Commercial Register">
  <data key="d0">Commercial Register</data>
  <data key="d1">data</data>
  <data key="d2">The Commercial Register is an official record where a Merchant specifies their business address.</data>
  <data key="d3">chunk-7b813a98432e97bd821133a34c3ab82c</data>
  <data key="d4">نظام_التجارة_الإلكترونية</data>
  <data key="d5">1776814494</data>
  <data key="d6"></data>
</node>
<node id="Electronic Office">
  <data key="d0">Electronic Office</data>
  <data key="d1">location</data>
  <data key="d2">The Electronic Office is a virtual space designated by a Practitioner to determine their place of business.</data>
  <data key="d3">chunk-7b813a98432e97bd821133a34c3ab82c</data>
  <data key="d4">نظام_التجارة_الإلكترونية</data>
  <data key="d5">1776814494</data>
  <data key="d6"></data>
</node>
<node id="Information System">
  <data key="d0">Information System</data>
  <data key="d1">artifact</data>
  <data key="d2">The Information System is the technical infrastructure used by the Service Provider to conclude contracts; its mere presence does not constitute a place of business.</data>
  <data key="d3">chunk-7b813a98432e97bd821133a34c3ab82c</data>
  <data key="d4">نظام_التجارة_الإلكترونية</data>
  <data key="d5">1776814494</data>
  <data key="d6"></data>
</node>
<node id="Domain Name">
  <data key="d0">Domain Name</data>
  <data key="d1">concept</data>
  <data key="d2">A Domain Name associated with a specific country does not create a presumption that the Service Provider's place of business is in that country.</data>
  <data key="d3">chunk-7b813a98432e97bd821133a34c3ab82c</data>
  <data key="d4">نظام_التجارة_الإلكترونية</data>
  <data key="d5">1776814494</data>
  <data key="d6"></data>
</node>
<node id="Natural Person">
  <data key="d0">Natural Person</data>
  <data key="d1">person</data>
  <data key="d2">A Natural Person is an individual practitioner who may lack a formal place of business, in which case their habitual residence is considered the place of business.</data>
  <data key="d3">chunk-7b813a98432e97bd821133a34c3ab82c</data>
  <data key="d4">نظام_التجارة_الإلكترونية</data>
  <data key="d5">1776814494</data>
  <data key="d6"></data>
</node>
<node id="Habitual Residence">
  <data key="d0">Habitual Residence</data>
  <data key="d1">location</data>
  <data key="d2">The Habitual Residence is the legal domicile of a natural person, serving as their deemed place of business if they lack a formal office.</data>
  <data key="d3">chunk-7b813a98432e97bd821133a34c3ab82c</data>
  <data key="d4">نظام_التجارة_الإلكترونية</data>
  <data key="d5">1776814494</data>
  <data key="d6"></data>
</node>
<node id="Place of Business">
  <data key="d0">Place of Business</data>
  <data key="d3">chunk-7b813a98432e97bd821133a34c3ab82c</data>
  <data key="d2">The mere presence of equipment supporting the Information System does not qualify a location as a place of business.</data>
  <data key="d1">UNKNOWN</data>
  <data key="d4">نظام_التجارة_الإلكترونية</data>
  <data key="d5">1776814494</data>
  <data key="d6"></data>
</node>
<node id="Country">
  <data key="d0">Country</data>
  <data key="d3">chunk-7b813a98432e97bd821133a34c3ab82c</data>
  <data key="d2">Using a domain name linked to a country does not presume the business is located there.</data>
  <data key="d1">UNKNOWN</data>
  <data key="d4">نظام_التجارة_الإلكترونية</data>
  <data key="d5">1776814494</data>
  <data key="d6"></data>
</node>
<node id="Communication Technology">
  <data key="d0">Communication Technology</data>
  <data key="d1">method</data>
  <data key="d2">Communication Technology is the medium through which electronic correspondence is transmitted.</data>
  <data key="d3">chunk-ef5c3f67882b7588927d8bca42047269</data>
  <data key="d4">نظام_التجارة_الإلكترونية</data>
  <data key="d5">1776814500</data>
  <data key="d6"></data>
</node>
<node id="Error Correction Notice">
  <data key="d0">Error Correction Notice</data>
  <data key="d1">content</data>
  <data key="d2">An Error Correction Notice is a formal notification submitted by the consumer to rectify mistakes in electronic communication.</data>
  <data key="d3">chunk-ef5c3f67882b7588927d8bca42047269</data>
  <data key="d4">نظام_التجارة_الإلكترونية</data>
  <data key="d5">1776814500</data>
  <data key="d6"></data>
</node>
<node id="Product Benefit">
  <data key="d0">Product Benefit</data>
  <data key="d1">concept</data>
  <data key="d2">Product Benefit refers to any advantage, service, or utility gained by the consumer from the provider's offerings.</data>
  <data key="d3">chunk-ef5c3f67882b7588927d8bca42047269</data>
  <data key="d4">نظام_التجارة_الإلكترونية</data>
  <data key="d5">1776814500</data>
  <data key="d6"></data>
</node>
<node id="Electronic Communications">
  <data key="d0">Electronic Communications</data>
  <data key="d1">content</data>
  <data key="d2">Electronic Communications are interactions between the Consumer and Service Provider that require privacy protection similar to Personal Data under the regulations.</data>
  <data key="d3">chunk-30e605d9deb7e33ed48fcf51264fb16e</data>
  <data key="d4">نظام_التجارة_الإلكترونية</data>
  <data key="d5">1776814508</data>
  <data key="d6"></data>
</node>
<node id="E-Commerce Transactions">
  <data key="d0">E-Commerce Transactions</data>
  <data key="d1">concept</data>
  <data key="d2">E-Commerce Transactions define the business context where the retention of Consumer data is permissible only for the duration necessary due to the nature of the trade.&lt;SEP&gt;E-commerce transactions are the subject matter under the supervision and inspection of the appointed employees.</data>
  <data key="d3">chunk-30e605d9deb7e33ed48fcf51264fb16e&lt;SEP&gt;chunk-9d902918ab9ab7a4b9783ccc6785c4da</data>
  <data key="d4">نظام_التجارة_الإلكترونية</data>
  <data key="d5">1776814633</data>
  <data key="d6"></data>
</node>
<node id="Regulatory Framework">
  <data key="d0">Regulatory Framework</data>
  <data key="d1">method</data>
  <data key="d2">The Regulatory Framework includes laws and regulations that dictate data protection standards, retention limits, and conditions for disclosing data to third parties.</data>
  <data key="d3">chunk-30e605d9deb7e33ed48fcf51264fb16e</data>
  <data key="d4">نظام_التجارة_الإلكترونية</data>
  <data key="d5">1776814508</data>
  <data key="d6"></data>
</node>
<node id="Third Parties">
  <data key="d0">Third Parties</data>
  <data key="d1">organization</data>
  <data key="d2">Third Parties are external entities to whom the Service Provider is prohibited from disclosing Consumer data unless authorized by law or with explicit Consumer consent.</data>
  <data key="d3">chunk-30e605d9deb7e33ed48fcf51264fb16e</data>
  <data key="d4">نظام_التجارة_الإلكترونية</data>
  <data key="d5">1776814508</data>
  <data key="d6"></data>
</node>
<node id="Article 5">
  <data key="d0">Article 5</data>
  <data key="d1">content</data>
  <data key="d2">Article 5 is the specific legal provision in the input text that establishes rules for data retention, privacy protection, and usage restrictions by Service Providers.</data>
  <data key="d3">chunk-30e605d9deb7e33ed48fcf51264fb16e</data>
  <data key="d4">نظام_التجارة_الإلكترونية</data>
  <data key="d5">1776814508</data>
  <data key="d6"></data>
</node>
<node id="Registration Authority">
  <data key="d0">Registration Authority</data>
  <data key="d1">organization</data>
  <data key="d2">A Registration Authority is an entity that verifies and records the registration of electronic business locations.&lt;SEP&gt;The entity under which the service provider is registered and from which licenses are issued.</data>
  <data key="d3">chunk-a02c96de615b73a0b4a82ae7b14bc537&lt;SEP&gt;chunk-17f12893b7ea3153ad9caac0b573a730</data>
  <data key="d4">نظام_التجارة_الإلكترونية</data>
  <data key="d5">1776814538</data>
  <data key="d6"></data>
</node>
<node id="Commercial Registry">
  <data key="d0">Commercial Registry</data>
  <data key="d1">organization</data>
  <data key="d2">The Commercial Registry is a public record containing details about registered businesses, including names and registry numbers.&lt;SEP&gt;The Commercial Registry is the official database where traders must record their electronic premises.</data>
  <data key="d3">chunk-a02c96de615b73a0b4a82ae7b14bc537&lt;SEP&gt;chunk-0287b0d01cfa4f5a98740f1886983a05</data>
  <data key="d4">نظام_التجارة_الإلكترونية</data>
  <data key="d5">1776814585</data>
  <data key="d6"></data>
</node>
<node id="Contract Statement">
  <data key="d0">Contract Statement</data>
  <data key="d1">content</data>
  <data key="d2">The Contract Statement is a document containing the terms, conditions, prices, and procedures related to the intended agreement.</data>
  <data key="d3">chunk-b0f30d8785ebf55f768a527b1ede688f</data>
  <data key="d4">نظام_التجارة_الإلكترونية</data>
  <data key="d5">1776814522</data>
  <data key="d6"></data>
</node>
<node id="Contract Procedures">
  <data key="d0">Contract Procedures</data>
  <data key="d1">method</data>
  <data key="d2">Procedures required for concluding the contract are part of the mandatory disclosure information.</data>
  <data key="d3">chunk-b0f30d8785ebf55f768a527b1ede688f</data>
  <data key="d4">نظام_التجارة_الإلكترونية</data>
  <data key="d5">1776814522</data>
  <data key="d6"></data>
</node>
<node id="Product or Service Characteristics">
  <data key="d0">Product or Service Characteristics</data>
  <data key="d1">data</data>
  <data key="d2">Essential features of the products or services subject to the contract must be disclosed.</data>
  <data key="d3">chunk-b0f30d8785ebf55f768a527b1ede688f</data>
  <data key="d4">نظام_التجارة_الإلكترونية</data>
  <data key="d5">1776814522</data>
  <data key="d6"></data>
</node>
<node id="Total Price">
  <data key="d0">Total Price</data>
  <data key="d1">data</data>
  <data key="d2">The total cost inclusive of all fees, taxes, and delivery charges must be clearly stated.&lt;SEP&gt;The Total Price includes all fees, taxes, and additional amounts related to delivery.</data>
  <data key="d3">chunk-b0f30d8785ebf55f768a527b1ede688f&lt;SEP&gt;chunk-ed4385a57314892c443871db0108ea1b</data>
  <data key="d4">نظام_التجارة_الإلكترونية</data>
  <data key="d5">1776814532</data>
  <data key="d6"></data>
</node>
<node id="Payment and Delivery Arrangements">
  <data key="d0">Payment and Delivery Arrangements</data>
  <data key="d1">method</data>
  <data key="d2">Details regarding payment methods, delivery logistics, and execution timelines are required in the statement.</data>
  <data key="d3">chunk-b0f30d8785ebf55f768a527b1ede688f</data>
  <data key="d4">نظام_التجارة_الإلكترونية</data>
  <data key="d5">1776814522</data>
  <data key="d6"></data>
</node>
<node id="Warranty Information">
  <data key="d0">Warranty Information</data>
  <data key="d1">data</data>
  <data key="d2">Information about available warranties must be included if applicable.</data>
  <data key="d3">chunk-b0f30d8785ebf55f768a527b1ede688f</data>
  <data key="d4">نظام_التجارة_الإلكترونية</data>
  <data key="d5">1776814522</data>
  <data key="d6"></data>
</node>
<node id="Service Provider Data">
  <data key="d0">Service Provider Data</data>
  <data key="d1">data</data>
  <data key="d2">Information related to the identity and details of the Service Provider that must be included in the statement.</data>
  <data key="d3">chunk-b0f30d8785ebf55f768a527b1ede688f</data>
  <data key="d4">نظام_التجارة_الإلكترونية</data>
  <data key="d5">1776814522</data>
  <data key="d6"></data>
</node>
<node id="Product Costs">
  <data key="d0">Product Costs</data>
  <data key="d1">data</data>
  <data key="d2">Product Costs are the specific expenses for each item purchased as detailed in the invoice.</data>
  <data key="d3">chunk-ed4385a57314892c443871db0108ea1b</data>
  <data key="d4">نظام_التجارة_الإلكترونية</data>
  <data key="d5">1776814532</data>
  <data key="d6"></data>
</node>
<node id="Delivery Date And Location">
  <data key="d0">Delivery Date And Location</data>
  <data key="d1">concept</data>
  <data key="d2">The Delivery Date And Location refers to the time and place of delivery specified in the invoice.</data>
  <data key="d3">chunk-ed4385a57314892c443871db0108ea1b</data>
  <data key="d4">نظام_التجارة_الإلكترونية</data>
  <data key="d5">1776814532</data>
  <data key="d6"></data>
</node>
<node id="Ninth Article">
  <data key="d0">Ninth Article</data>
  <data key="d1">content</data>
  <data key="d2">The legal article mandating disclosure requirements for licensed service providers.</data>
  <data key="d3">chunk-17f12893b7ea3153ad9caac0b573a730</data>
  <data key="d4">نظام_التجارة_الإلكترونية</data>
  <data key="d5">1776814538</data>
  <data key="d6"></data>
</node>
<node id="License Or Permit">
  <data key="d0">License Or Permit</data>
  <data key="d1">data</data>
  <data key="d2">Official documentation authorizing the practice of a regulated profession, issued by the registration authority.</data>
  <data key="d3">chunk-17f12893b7ea3153ad9caac0b573a730</data>
  <data key="d4">نظام_التجارة_الإلكترونية</data>
  <data key="d5">1776814538</data>
  <data key="d6"></data>
</node>
<node id="Professional Title">
  <data key="d0">Professional Title</data>
  <data key="d1">concept</data>
  <data key="d2">The professional designation held by the service provider, granted by a specific country.</data>
  <data key="d3">chunk-17f12893b7ea3153ad9caac0b573a730</data>
  <data key="d4">نظام_التجارة_الإلكترونية</data>
  <data key="d5">1776814538</data>
  <data key="d6"></data>
</node>
<node id="Granting Country">
  <data key="d0">Granting Country</data>
  <data key="d1">location</data>
  <data key="d2">The nation that issued the professional title to the service provider.</data>
  <data key="d3">chunk-17f12893b7ea3153ad9caac0b573a730</data>
  <data key="d4">نظام_التجارة_الإلكترونية</data>
  <data key="d5">1776814538</data>
  <data key="d6"></data>
</node>
<node id="Regulatory Bylaws">
  <data key="d0">Regulatory Bylaws</data>
  <data key="d1">content</data>
  <data key="d2">Rules specifying additional data points that must be disclosed by the service provider.&lt;SEP&gt;Legal regulations that determine other data requirements for the electronic declaration.</data>
  <data key="d3">chunk-17f12893b7ea3153ad9caac0b573a730&lt;SEP&gt;chunk-d54b07a7c7ab7c081f38bdd3d484ecc7</data>
  <data key="d4">نظام_التجارة_الإلكترونية</data>
  <data key="d5">1776814544</data>
  <data key="d6"></data>
</node>
<node id="Regulated Profession">
  <data key="d0">Regulated Profession</data>
  <data key="d1">concept</data>
  <data key="d2">The profession practiced by the service provider, which is subject to specific regulations and licensing requirements.</data>
  <data key="d3">chunk-17f12893b7ea3153ad9caac0b573a730</data>
  <data key="d4">نظام_التجارة_الإلكترونية</data>
  <data key="d5">1776814538</data>
  <data key="d6"></data>
</node>
<node id="Electronic Declaration">
  <data key="d0">Electronic Declaration</data>
  <data key="d1">content</data>
  <data key="d2">The Electronic Declaration is a contractual document that complements contracts and is binding on the parties involved.</data>
  <data key="d3">chunk-d54b07a7c7ab7c081f38bdd3d484ecc7</data>
  <data key="d4">نظام_التجارة_الإلكترونية</data>
  <data key="d5">1776814544</data>
  <data key="d6"></data>
</node>
<node id="Contract Parties">
  <data key="d0">Contract Parties</data>
  <data key="d1">person</data>
  <data key="d2">The parties to the contract who are bound by the electronic declaration.</data>
  <data key="d3">chunk-d54b07a7c7ab7c081f38bdd3d484ecc7</data>
  <data key="d4">نظام_التجارة_الإلكترونية</data>
  <data key="d5">1776814544</data>
  <data key="d6"></data>
</node>
<node id="Product Or Service Name">
  <data key="d0">Product Or Service Name</data>
  <data key="d1">concept</data>
  <data key="d2">A required element of the electronic declaration, identifying the product or service being advertised.</data>
  <data key="d3">chunk-d54b07a7c7ab7c081f38bdd3d484ecc7</data>
  <data key="d4">نظام_التجارة_الإلكترونية</data>
  <data key="d5">1776814544</data>
  <data key="d6"></data>
</node>
<node id="Electronics Business Authentication Authorities">
  <data key="d0">Electronics Business Authentication Authorities</data>
  <data key="d1">organization</data>
  <data key="d2">Authorities responsible for authenticating electronics businesses, referenced when distinguishing statements about the service provider are not registered.</data>
  <data key="d3">chunk-d54b07a7c7ab7c081f38bdd3d484ecc7</data>
  <data key="d4">نظام_التجارة_الإلكترونية</data>
  <data key="d5">1776814544</data>
  <data key="d6"></data>
</node>
<node id="Communication Channels">
  <data key="d0">Communication Channels</data>
  <data key="d1">method</data>
  <data key="d2">Means of contacting the service provider, which must be specified in the electronic declaration.</data>
  <data key="d3">chunk-d54b07a7c7ab7c081f38bdd3d484ecc7</data>
  <data key="d4">نظام_التجارة_الإلكترونية</data>
  <data key="d5">1776814544</data>
  <data key="d6"></data>
</node>
<node id="Electronic Contracts">
  <data key="d0">Electronic Contracts</data>
  <data key="d1">content</data>
  <data key="d2">Contracts that are complemented by the electronic declaration.</data>
  <data key="d3">chunk-d54b07a7c7ab7c081f38bdd3d484ecc7</data>
  <data key="d4">نظام_التجارة_الإلكترونية</data>
  <data key="d5">1776814544</data>
  <data key="d6"></data>
</node>
<node id="False Representation">
  <data key="d0">False Representation</data>
  <data key="d1">concept</data>
  <data key="d2">False Representation includes displays, statements, or claims that are false or formulated to directly or indirectly deceive or mislead consumers.</data>
  <data key="d3">chunk-7dce39ad69ab952b0a24c9573b89731d</data>
  <data key="d4">نظام_التجارة_الإلكترونية</data>
  <data key="d5">1776814549</data>
  <data key="d6"></data>
</node>
<node id="Trademark">
  <data key="d0">Trademark</data>
  <data key="d1">artifact</data>
  <data key="d2">Trademark refers to logos or brands owned by the service provider; using unauthorized or counterfeit trademarks is prohibited.</data>
  <data key="d3">chunk-7dce39ad69ab952b0a24c9573b89731d</data>
  <data key="d4">نظام_التجارة_الإلكترونية</data>
  <data key="d5">1776814549</data>
  <data key="d6"></data>
</node>
<node id="Article 12">
  <data key="d0">Article 12</data>
  <data key="d1">content</data>
  <data key="d2">Article 12 establishes the conditions under which a service provider can be compelled to remove non-compliant advertisements or content.</data>
  <data key="d3">chunk-a679e1dd369b0584601fe4f3f1b24454</data>
  <data key="d4">نظام_التجارة_الإلكترونية</data>
  <data key="d5">1776814556</data>
  <data key="d6"></data>
</node>
<node id="Administrative Penalties Regime">
  <data key="d0">Administrative Penalties Regime</data>
  <data key="d1">concept</data>
  <data key="d2">The administrative penalties regime refers to the system of sanctions outlined in Article 18 of the Regulations, which remains unaffected by the provisions of Article 12.</data>
  <data key="d3">chunk-a679e1dd369b0584601fe4f3f1b24454</data>
  <data key="d4">نظام_التجارة_الإلكترونية</data>
  <data key="d5">1776814556</data>
  <data key="d6"></data>
</node>
<node id="Violations of Paragraph (2) of Article 10">
  <data key="d0">Violations of Paragraph (2) of Article 10</data>
  <data key="d1">concept</data>
  <data key="d2">Violations of Paragraph (2) of Article 10 refer to specific breaches of regulatory requirements that trigger enforcement actions under Article 12.</data>
  <data key="d3">chunk-a679e1dd369b0584601fe4f3f1b24454</data>
  <data key="d4">نظام_التجارة_الإلكترونية</data>
  <data key="d5">1776814556</data>
  <data key="d6"></data>
</node>
<node id="Violations of Article 11">
  <data key="d0">Violations of Article 11</data>
  <data key="d1">concept</data>
  <data key="d2">Violations of Article 11 refer to breaches of the regulations specified in Article 11, serving as grounds for ministerial intervention.</data>
  <data key="d3">chunk-a679e1dd369b0584601fe4f3f1b24454</data>
  <data key="d4">نظام_التجارة_الإلكترونية</data>
  <data key="d5">1776814556</data>
  <data key="d6"></data>
</node>
<node id="Ministry">
  <data key="d0">Ministry</data>
  <data key="d1">organization</data>
  <data key="d2">The Ministry is the governmental authority empowered to mandate the removal of violations or withdrawal of advertisements from service providers.</data>
  <data key="d3">chunk-a679e1dd369b0584601fe4f3f1b24454</data>
  <data key="d4">نظام_التجارة_الإلكترونية</data>
  <data key="d5">1776814556</data>
  <data key="d6"></data>
</node>
<node id="Violation Removal">
  <data key="d0">Violation Removal</data>
  <data key="d1">method</data>
  <data key="d2">Violation Removal is the action required from the service provider to rectify non-compliance with the Regulations.</data>
  <data key="d3">chunk-a679e1dd369b0584601fe4f3f1b24454</data>
  <data key="d4">نظام_التجارة_الإلكترونية</data>
  <data key="d5">1776814556</data>
  <data key="d6"></data>
</node>
<node id="Advertisement Withdrawal">
  <data key="d0">Advertisement Withdrawal</data>
  <data key="d1">method</data>
  <data key="d2">Advertisement Withdrawal is the process of recalling an advertisement from circulation within one day of notification.</data>
  <data key="d3">chunk-a679e1dd369b0584601fe4f3f1b24454</data>
  <data key="d4">نظام_التجارة_الإلكترونية</data>
  <data key="d5">1776814556</data>
  <data key="d6"></data>
</node>
<node id="One-Day Deadline">
  <data key="d0">One-Day Deadline</data>
  <data key="d1">concept</data>
  <data key="d2">The One-Day Deadline specifies the timeframe within which a service provider must comply with the Ministry's order to remove violations or withdraw advertisements.</data>
  <data key="d3">chunk-a679e1dd369b0584601fe4f3f1b24454</data>
  <data key="d4">نظام_التجارة_الإلكترونية</data>
  <data key="d5">1776814556</data>
  <data key="d6"></data>
</node>
<node id="Article 18">
  <data key="d0">Article 18</data>
  <data key="d1">content</data>
  <data key="d2">Article 18 of the Regulations outlines the administrative penalties regime, which remains applicable and unaffected by the provisions in Article 12.</data>
  <data key="d3">chunk-a679e1dd369b0584601fe4f3f1b24454</data>
  <data key="d4">نظام_التجارة_الإلكترونية</data>
  <data key="d5">1776814556</data>
  <data key="d6"></data>
</node>
<node id="Article 13">
  <data key="d0">Article 13</data>
  <data key="d1">content</data>
  <data key="d2">Article 13 is a legal provision defining the consumer's right to withdraw from contracts and the exceptions to this right.</data>
  <data key="d3">chunk-98520f83d72a9bac06aacc6991d7d823</data>
  <data key="d4">نظام_التجارة_الإلكترونية</data>
  <data key="d5">1776814570</data>
  <data key="d6"></data>
</node>
<node id="Contracting Date">
  <data key="d0">Contracting Date</data>
  <data key="d1">data</data>
  <data key="d2">The date on which the service was contracted, serving as an alternative start point for the withdrawal period if no product delivery occurred.</data>
  <data key="d3">chunk-98520f83d72a9bac06aacc6991d7d823</data>
  <data key="d4">نظام_التجارة_الإلكترونية</data>
  <data key="d5">1776814570</data>
  <data key="d6"></data>
</node>
<node id="Custom-Produced Products">
  <data key="d0">Custom-Produced Products</data>
  <data key="d1">naturalobject</data>
  <data key="d2">Products manufactured based on specific consumer requests or specifications, generally excluded from the right of withdrawal unless defective.</data>
  <data key="d3">chunk-98520f83d72a9bac06aacc6991d7d823</data>
  <data key="d4">نظام_التجارة_الإلكترونية</data>
  <data key="d5">1776814570</data>
  <data key="d6"></data>
</node>
<node id="Used Media And Software">
  <data key="d0">Used Media And Software</data>
  <data key="d1">artifact</data>
  <data key="d2">Video tapes, discs, compact discs, or information software that have been used, excluding these from the standard right of withdrawal.</data>
  <data key="d3">chunk-98520f83d72a9bac06aacc6991d7d823</data>
  <data key="d4">نظام_التجارة_الإلكترونية</data>
  <data key="d5">1776814570</data>
  <data key="d6"></data>
</node>
<node id="Periodicals">
  <data key="d0">Periodicals</data>
  <data key="d1">content</data>
  <data key="d2">Newspapers, magazines, publications, or books, which are exempt from the consumer's right of withdrawal.</data>
  <data key="d3">chunk-98520f83d72a9bac06aacc6991d7d823</data>
  <data key="d4">نظام_التجارة_الإلكترونية</data>
  <data key="d5">1776814570</data>
  <data key="d6"></data>
</node>
<node id="Service Providers">
  <data key="d0">Service Providers</data>
  <data key="d1">organization</data>
  <data key="d2">Entities providing services such as accommodation, transportation, or feeding, whose contracts are exempt from the withdrawal right.</data>
  <data key="d3">chunk-98520f83d72a9bac06aacc6991d7d823</data>
  <data key="d4">نظام_التجارة_الإلكترونية</data>
  <data key="d5">1776814570</data>
  <data key="d6"></data>
</node>
<node id="Online Downloaded Products">
  <data key="d0">Online Downloaded Products</data>
  <data key="d1">data</data>
  <data key="d2">Software or digital products downloaded via the internet, exempt from withdrawal rights unless defective or non-compliant.</data>
  <data key="d3">chunk-98520f83d72a9bac06aacc6991d7d823</data>
  <data key="d4">نظام_التجارة_الإلكترونية</data>
  <data key="d5">1776814570</data>
  <data key="d6"></data>
</node>
<node id="Defects">
  <data key="d0">Defects</data>
  <data key="d1">concept</data>
  <data key="d2">Flaws or non-compliance with agreed specifications that preserve the consumer's right to withdraw even for otherwise exempt categories.</data>
  <data key="d3">chunk-98520f83d72a9bac06aacc6991d7d823</data>
  <data key="d4">نظام_التجارة_الإلكترونية</data>
  <data key="d5">1776814570</data>
  <data key="d6"></data>
</node>
<node id="Costs">
  <data key="d0">Costs</data>
  <data key="d3">chunk-98520f83d72a9bac06aacc6991d7d823</data>
  <data key="d2">The Consumer bears costs associated with contract withdrawal if they derive benefit from the service or product before withdrawing.</data>
  <data key="d1">UNKNOWN</data>
  <data key="d4">نظام_التجارة_الإلكترونية</data>
  <data key="d5">1776814571</data>
  <data key="d6"></data>
</node>
<node id="Fifteen-Day Period">
  <data key="d0">Fifteen-Day Period</data>
  <data key="d1">time</data>
  <data key="d2">The Fifteen-Day Period is the maximum allowable delay in delivery or execution before the Consumer can terminate the contract.</data>
  <data key="d3">chunk-c0d47d22075e87911525f2b1b1a29585</data>
  <data key="d4">نظام_التجارة_الإلكترونية</data>
  <data key="d5">1776814578</data>
  <data key="d6"></data>
</node>
<node id="Force Majeure">
  <data key="d0">Force Majeure</data>
  <data key="d1">concept</data>
  <data key="d2">Force Majeure refers to unforeseeable circumstances that prevent someone from fulfilling a contract, exempting the Service Provider from liability for delay.</data>
  <data key="d3">chunk-c0d47d22075e87911525f2b1b1a29585</data>
  <data key="d4">نظام_التجارة_الإلكترونية</data>
  <data key="d5">1776814578</data>
  <data key="d6"></data>
</node>
<node id="Expected Delay Notification">
  <data key="d0">Expected Delay Notification</data>
  <data key="d1">method</data>
  <data key="d2">The requirement for the Service Provider to inform the Consumer of any expected delays or significant difficulties affecting delivery.</data>
  <data key="d3">chunk-c0d47d22075e87911525f2b1b1a29585</data>
  <data key="d4">نظام_التجارة_الإلكترونية</data>
  <data key="d5">1776814578</data>
  <data key="d6"></data>
</node>
<node id="Delay Costs">
  <data key="d0">Delay Costs</data>
  <data key="d1">concept</data>
  <data key="d2">Delay Costs refer to additional costs incurred by the Consumer as a result of the Service Provider's failure to deliver or execute on time.</data>
  <data key="d3">chunk-c0d47d22075e87911525f2b1b1a29585</data>
  <data key="d4">نظام_التجارة_الإلكترونية</data>
  <data key="d5">1776814578</data>
  <data key="d6"></data>
</node>
<node id="Trader">
  <data key="d0">Trader</data>
  <data key="d1">person</data>
  <data key="d2">The Trader is the subject required to register their electronic premises in the commercial registry.</data>
  <data key="d3">chunk-0287b0d01cfa4f5a98740f1886983a05</data>
  <data key="d4">نظام_التجارة_الإلكترونية</data>
  <data key="d5">1776814585</data>
  <data key="d6"></data>
</node>
<node id="Electronic Premises">
  <data key="d0">Electronic Premises</data>
  <data key="d1">location</data>
  <data key="d2">The electronic premises refer to the trader's online business presence or store that must be registered.&lt;SEP&gt;The digital location or platform operated by the Service Provider that can be partially or fully blocked by the Minister.&lt;SEP&gt;Online business locations that may be blocked partially or fully in coordination with competent authorities.</data>
  <data key="d3">chunk-0287b0d01cfa4f5a98740f1886983a05&lt;SEP&gt;chunk-db15b26408bc87ab744a17b5b0ea6317&lt;SEP&gt;chunk-f5661f438c3dca334dc944b7a2eeeb87</data>
  <data key="d4">نظام_التجارة_الإلكترونية</data>
  <data key="d5">1776814603</data>
  <data key="d6"></data>
</node>
<node id="Commercial Registry System">
  <data key="d0">Commercial Registry System</data>
  <data key="d1">method</data>
  <data key="d2">The Commercial Registry System is the regulatory framework governing the registration process for traders.</data>
  <data key="d3">chunk-0287b0d01cfa4f5a98740f1886983a05</data>
  <data key="d4">نظام_التجارة_الإلكترونية</data>
  <data key="d5">1776814585</data>
  <data key="d6"></data>
</node>
<node id="The Ministry">
  <data key="d0">The Ministry</data>
  <data key="d1">organization</data>
  <data key="d2">The Ministry is the governmental body responsible for supervising the e-commerce sector and issuing necessary regulations to enhance its role and protect transaction integrity.</data>
  <data key="d3">chunk-b93d95a5b6df178db9b2bb6cde162f61</data>
  <data key="d4">نظام_التجارة_الإلكترونية</data>
  <data key="d5">1776814589</data>
  <data key="d6"></data>
</node>
<node id="E-Commerce Sector">
  <data key="d0">E-Commerce Sector</data>
  <data key="d1">concept</data>
  <data key="d2">The E-Commerce Sector is the industry area supervised by the Ministry, involving online commercial activities and digital transactions.</data>
  <data key="d3">chunk-b93d95a5b6df178db9b2bb6cde162f61</data>
  <data key="d4">نظام_التجارة_الإلكترونية</data>
  <data key="d5">1776814589</data>
  <data key="d6"></data>
</node>
<node id="Electronic Verification Entities">
  <data key="d0">Electronic Verification Entities</data>
  <data key="d1">organization</data>
  <data key="d2">Electronic Verification Entities are organizations whose role involves certifying or verifying electronic establishments, subject to regulation by the Ministry.</data>
  <data key="d3">chunk-b93d95a5b6df178db9b2bb6cde162f61</data>
  <data key="d4">نظام_التجارة_الإلكترونية</data>
  <data key="d5">1776814589</data>
  <data key="d6"></data>
</node>
<node id="Transaction Integrity">
  <data key="d0">Transaction Integrity</data>
  <data key="d1">concept</data>
  <data key="d2">Transaction Integrity refers to the safety and security of dealings within the e-commerce sector, which the Ministry aims to protect through regulation.</data>
  <data key="d3">chunk-b93d95a5b6df178db9b2bb6cde162f61</data>
  <data key="d4">نظام_التجارة_الإلكترونية</data>
  <data key="d5">1776814589</data>
  <data key="d6"></data>
</node>
<node id="Minister">
  <data key="d0">Minister</data>
  <data key="d1">person</data>
  <data key="d2">The Minister is a government official authorized to take urgent decisions regarding violations of the System or Regulation.&lt;SEP&gt;The Minister is responsible for forming the committee, issuing operational rules, and determining member allowances.</data>
  <data key="d3">chunk-db15b26408bc87ab744a17b5b0ea6317&lt;SEP&gt;chunk-bdd31cd82935851ed60fa97049b2dc09</data>
  <data key="d4">نظام_التجارة_الإلكترونية</data>
  <data key="d5">1776814610</data>
  <data key="d6"></data>
</node>
<node id="Article Seventeen">
  <data key="d0">Article Seventeen</data>
  <data key="d1">content</data>
  <data key="d2">Article Seventeen of the System detailing the procedures for blocking Electronic Premises and referring violations to the Committee.</data>
  <data key="d3">chunk-db15b26408bc87ab744a17b5b0ea6317</data>
  <data key="d4">نظام_التجارة_الإلكترونية</data>
  <data key="d5">1776814597</data>
  <data key="d6"></data>
</node>
<node id="Three Days">
  <data key="d0">Three Days</data>
  <data key="d1">concept</data>
  <data key="d2">The maximum time period, in days, within which the Minister must refer a violation to the Committee after blocking the electronic premises.</data>
  <data key="d3">chunk-db15b26408bc87ab744a17b5b0ea6317</data>
  <data key="d4">نظام_التجارة_الإلكترونية</data>
  <data key="d5">1776814597</data>
  <data key="d6"></data>
</node>
<node id="Violation">
  <data key="d0">Violation</data>
  <data key="d3">chunk-db15b26408bc87ab744a17b5b0ea6317</data>
  <data key="d2">The Committee must render its decision on the violation within ten days from the date of referral.</data>
  <data key="d1">UNKNOWN</data>
  <data key="d4">نظام_التجارة_الإلكترونية</data>
  <data key="d5">1776814597</data>
  <data key="d6"></data>
</node>
<node id="Electronic Commerce Practice">
  <data key="d0">Electronic Commerce Practice</data>
  <data key="d1">concept</data>
  <data key="d2">The practice of conducting commerce online, which can be suspended as a penalty for non-compliance.</data>
  <data key="d3">chunk-f5661f438c3dca334dc944b7a2eeeb87</data>
  <data key="d4">نظام_التجارة_الإلكترونية</data>
  <data key="d5">1776814603</data>
  <data key="d6"></data>
</node>
<node id="Suspension Of Electronic Commerce">
  <data key="d0">Suspension Of Electronic Commerce</data>
  <data key="d1">event</data>
  <data key="d2">The temporary or permanent cessation of electronic commerce activities as a punitive measure.</data>
  <data key="d3">chunk-f5661f438c3dca334dc944b7a2eeeb87</data>
  <data key="d4">نظام_التجارة_الإلكترونية</data>
  <data key="d5">1776814603</data>
  <data key="d6"></data>
</node>
<node id="Blocking Of Electronic Premises">
  <data key="d0">Blocking Of Electronic Premises</data>
  <data key="d1">method</data>
  <data key="d2">The partial or total obstruction of access to online business premises, coordinated with competent authorities.</data>
  <data key="d3">chunk-f5661f438c3dca334dc944b7a2eeeb87</data>
  <data key="d4">نظام_التجارة_الإلكترونية</data>
  <data key="d5">1776814603</data>
  <data key="d6"></data>
</node>
<node id="Other Regulations">
  <data key="d0">Other Regulations</data>
  <data key="d1">organization</data>
  <data key="d2">Other legal systems or regulations that may prescribe harsher penalties than those outlined in Article Eighteen.</data>
  <data key="d3">chunk-f5661f438c3dca334dc944b7a2eeeb87</data>
  <data key="d4">نظام_التجارة_الإلكترونية</data>
  <data key="d5">1776814604</data>
  <data key="d6"></data>
</node>
<node id="Bylaw">
  <data key="d0">Bylaw</data>
  <data key="d1">concept</data>
  <data key="d2">The Bylaw contains specific provisions that the Committee reviews for violations.</data>
  <data key="d3">chunk-bdd31cd82935851ed60fa97049b2dc09</data>
  <data key="d4">نظام_التجارة_الإلكترونية</data>
  <data key="d5">1776814611</data>
  <data key="d6"></data>
</node>
<node id="Administrative Advisor">
  <data key="d0">Administrative Advisor</data>
  <data key="d1">person</data>
  <data key="d2">An Administrative Advisor is a mandatory member of the Committee, ensuring at least one such role is present.</data>
  <data key="d3">chunk-bdd31cd82935851ed60fa97049b2dc09</data>
  <data key="d4">نظام_التجارة_الإلكترونية</data>
  <data key="d5">1776814611</data>
  <data key="d6"></data>
</node>
<node id="Committee Decision">
  <data key="d0">Committee Decision</data>
  <data key="d1">concept</data>
  <data key="d2">Decisions made by the Committee are issued by majority vote.</data>
  <data key="d3">chunk-bdd31cd82935851ed60fa97049b2dc09</data>
  <data key="d4">نظام_التجارة_الإلكترونية</data>
  <data key="d5">1776814611</data>
  <data key="d6"></data>
</node>
<node id="Service Provider Activity">
  <data key="d0">Service Provider Activity</data>
  <data key="d1">data</data>
  <data key="d2">The size and scope of the Service Provider's activity is a factor in determining penalties.</data>
  <data key="d3">chunk-bdd31cd82935851ed60fa97049b2dc09</data>
  <data key="d4">نظام_التجارة_الإلكترونية</data>
  <data key="d5">1776814611</data>
  <data key="d6"></data>
</node>
<node id="Recidivism">
  <data key="d0">Recidivism</data>
  <data key="d3">chunk-bdd31cd82935851ed60fa97049b2dc09</data>
  <data key="d2">The choice of penalty considers the frequency of the violation.</data>
  <data key="d1">UNKNOWN</data>
  <data key="d4">نظام_التجارة_الإلكترونية</data>
  <data key="d5">1776814611</data>
  <data key="d6"></data>
</node>
<node id="Service Provider Size">
  <data key="d0">Service Provider Size</data>
  <data key="d3">chunk-bdd31cd82935851ed60fa97049b2dc09</data>
  <data key="d2">The choice of penalty considers the scale of the Service Provider's activity.</data>
  <data key="d1">UNKNOWN</data>
  <data key="d4">نظام_التجارة_الإلكترونية</data>
  <data key="d5">1776814612</data>
  <data key="d6"></data>
</node>
<node id="Third-Party Harm">
  <data key="d0">Third-Party Harm</data>
  <data key="d3">chunk-bdd31cd82935851ed60fa97049b2dc09</data>
  <data key="d2">The choice of penalty considers the damage caused to others.</data>
  <data key="d1">UNKNOWN</data>
  <data key="d4">نظام_التجارة_الإلكترونية</data>
  <data key="d5">1776814612</data>
  <data key="d6"></data>
</node>
<node id="المادة العشرون">
  <data key="d0">المادة العشرون</data>
  <data key="d1">content</data>
  <data key="d2">Article Twenty is a legal provision regarding the right to appeal administrative decisions.</data>
  <data key="d3">chunk-2e5edf0ea88592648169855ce547cfd5</data>
  <data key="d4">نظام_التجارة_الإلكترونية</data>
  <data key="d5">1776814617</data>
  <data key="d6"></data>
</node>
<node id="Administrative Decision">
  <data key="d0">Administrative Decision</data>
  <data key="d1">event</data>
  <data key="d2">An administrative decision issued against an individual, serving as the subject of the potential appeal.</data>
  <data key="d3">chunk-2e5edf0ea88592648169855ce547cfd5</data>
  <data key="d4">نظام_التجارة_الإلكترونية</data>
  <data key="d5">1776814617</data>
  <data key="d6"></data>
</node>
<node id="Administrative Court">
  <data key="d0">Administrative Court</data>
  <data key="d1">organization</data>
  <data key="d2">The Administrative Court is the judicial body where appeals against administrative decisions are filed.</data>
  <data key="d3">chunk-2e5edf0ea88592648169855ce547cfd5</data>
  <data key="d4">نظام_التجارة_الإلكترونية</data>
  <data key="d5">1776814617</data>
  <data key="d6"></data>
</node>
<node id="Diwan Al-Muzalim">
  <data key="d0">Diwan Al-Muzalim</data>
  <data key="d1">organization</data>
  <data key="d2">Diwan Al-Muzalim is the institution overseeing the administration of justice and handling grievances.</data>
  <data key="d3">chunk-2e5edf0ea88592648169855ce547cfd5</data>
  <data key="d4">نظام_التجارة_الإلكترونية</data>
  <data key="d5">1776814617</data>
  <data key="d6"></data>
</node>
<node id="Diwan Al-Muzalim Litigation System">
  <data key="d0">Diwan Al-Muzalim Litigation System</data>
  <data key="d1">method</data>
  <data key="d2">The litigation system governing procedures and rules for cases heard before Diwan Al-Muzalim.</data>
  <data key="d3">chunk-2e5edf0ea88592648169855ce547cfd5</data>
  <data key="d4">نظام_التجارة_الإلكترونية</data>
  <data key="d5">1776814617</data>
  <data key="d6"></data>
</node>
<node id="Penalty Decision">
  <data key="d0">Penalty Decision</data>
  <data key="d1">concept</data>
  <data key="d2">The Penalty Decision is a ruling determining a punishment, which may include an order for its publication at the violator's expense.</data>
  <data key="d3">chunk-85d489500ac41fa5ad12a8c9462979b4</data>
  <data key="d4">نظام_التجارة_الإلكترونية</data>
  <data key="d5">1776814626</data>
  <data key="d6"></data>
</node>
<node id="Violator">
  <data key="d0">Violator</data>
  <data key="d1">person</data>
  <data key="d2">The Violator is the individual or entity responsible for the offense and is required to bear the costs of publishing the penalty decision.</data>
  <data key="d3">chunk-85d489500ac41fa5ad12a8c9462979b4</data>
  <data key="d4">نظام_التجارة_الإلكترونية</data>
  <data key="d5">1776814626</data>
  <data key="d6"></data>
</node>
<node id="Publication">
  <data key="d0">Publication</data>
  <data key="d1">event</data>
  <data key="d2">Publication refers to the act of making the content of the penalty decision public through newspapers or other suitable media.</data>
  <data key="d3">chunk-85d489500ac41fa5ad12a8c9462979b4</data>
  <data key="d4">نظام_التجارة_الإلكترونية</data>
  <data key="d5">1776814626</data>
  <data key="d6"></data>
</node>
<node id="Legal Period">
  <data key="d0">Legal Period</data>
  <data key="d1">concept</data>
  <data key="d2">The Legal Period is the specific time frame mandated by law that must elapse before a decision becomes enforceable for publication.</data>
  <data key="d3">chunk-85d489500ac41fa5ad12a8c9462979b4</data>
  <data key="d4">نظام_التجارة_الإلكترونية</data>
  <data key="d5">1776814626</data>
  <data key="d6"></data>
</node>
<node id="Final Judgment">
  <data key="d0">Final Judgment</data>
  <data key="d1">concept</data>
  <data key="d2">The Final Judgment is a legal status indicating that a ruling has become definitive and unappealable.</data>
  <data key="d3">chunk-85d489500ac41fa5ad12a8c9462979b4</data>
  <data key="d4">نظام_التجارة_الإلكترونية</data>
  <data key="d5">1776814626</data>
  <data key="d6"></data>
</node>
<node id="المادة الثانية والعشرون">
  <data key="d0">المادة الثانية والعشرون</data>
  <data key="d1">content</data>
  <data key="d2">Article 22 is a legal provision establishing the jurisdiction of specialized courts to resolve disputes and compensation claims arising from the application of system regulations.</data>
  <data key="d3">chunk-505a7da5372dbf86a3bdc9b55579249e</data>
  <data key="d4">نظام_التجارة_الإلكترونية</data>
  <data key="d5">1776814629</data>
  <data key="d6"></data>
</node>
<node id="المحكمة المختصة">
  <data key="d0">المحكمة المختصة</data>
  <data key="d3">chunk-505a7da5372dbf86a3bdc9b55579249e</data>
  <data key="d2">Article 22 grants the specialized court the authority to adjudicate disputes and compensation claims under this regulation.</data>
  <data key="d1">UNKNOWN</data>
  <data key="d4">نظام_التجارة_الإلكترونية</data>
  <data key="d5">1776814629</data>
  <data key="d6"></data>
</node>
<node id="The Minister">
  <data key="d0">The Minister</data>
  <data key="d1">person</data>
  <data key="d2">The Minister is the authority who issues the appointment decisions for employees responsible for oversight.&lt;SEP&gt;The Minister is the government official responsible for issuing regulations within a specified timeframe.</data>
  <data key="d3">chunk-9d902918ab9ab7a4b9783ccc6785c4da&lt;SEP&gt;chunk-3323a5605fc02cf6b08e6daf15866451</data>
  <data key="d4">نظام_التجارة_الإلكترونية</data>
  <data key="d5">1776814642</data>
  <data key="d6"></data>
</node>
<node id="Employees">
  <data key="d0">Employees</data>
  <data key="d1">person</data>
  <data key="d2">Employees are appointed by the Minister to conduct supervision, inspection, and violation control in e-commerce.</data>
  <data key="d3">chunk-9d902918ab9ab7a4b9783ccc6785c4da</data>
  <data key="d4">نظام_التجارة_الإلكترونية</data>
  <data key="d5">1776814633</data>
  <data key="d6"></data>
</node>
<node id="System Provisions">
  <data key="d0">System Provisions</data>
  <data key="d1">content</data>
  <data key="d2">System provisions contain regulations whose violations are monitored and controlled by the employees.</data>
  <data key="d3">chunk-9d902918ab9ab7a4b9783ccc6785c4da</data>
  <data key="d4">نظام_التجارة_الإلكترونية</data>
  <data key="d5">1776814633</data>
  <data key="d6"></data>
</node>
<node id="Regulation Bylaws">
  <data key="d0">Regulation Bylaws</data>
  <data key="d1">content</data>
  <data key="d2">Regulation bylaws contain rules whose violations are monitored and controlled by the employees.</data>
  <data key="d3">chunk-9d902918ab9ab7a4b9783ccc6785c4da</data>
  <data key="d4">نظام_التجارة_الإلكترونية</data>
  <data key="d5">1776814633</data>
  <data key="d6"></data>
</node>
<node id="Article Twenty-Three">
  <data key="d0">Article Twenty-Three</data>
  <data key="d1">content</data>
  <data key="d2">Article Twenty-Three is the legal provision that establishes the roles and responsibilities for supervising e-commerce transactions.</data>
  <data key="d3">chunk-9d902918ab9ab7a4b9783ccc6785c4da</data>
  <data key="d4">نظام_التجارة_الإلكترونية</data>
  <data key="d5">1776814633</data>
  <data key="d6"></data>
</node>
<node id="Article Twenty-Four">
  <data key="d0">Article Twenty-Four</data>
  <data key="d1">content</data>
  <data key="d2">Article Twenty-Four specifies the legal framework for e-commerce in cases where no specific provisions exist within the system.</data>
  <data key="d3">chunk-4356d14be0458851058bcbfa4dd8eff9</data>
  <data key="d4">نظام_التجارة_الإلكترونية</data>
  <data key="d5">1776814638</data>
  <data key="d6"></data>
</node>
<node id="Electronic Transactions Law">
  <data key="d0">Electronic Transactions Law</data>
  <data key="d1">method</data>
  <data key="d2">The Electronic Transactions Law is a legal system that provides the default rules applicable to e-commerce transactions not explicitly detailed elsewhere.</data>
  <data key="d3">chunk-4356d14be0458851058bcbfa4dd8eff9</data>
  <data key="d4">نظام_التجارة_الإلكترونية</data>
  <data key="d5">1776814638</data>
  <data key="d6"></data>
</node>
<node id="Related Systems">
  <data key="d0">Related Systems</data>
  <data key="d1">other</data>
  <data key="d2">Other related systems are supplementary legal frameworks that may apply to e-commerce alongside the Electronic Transactions Law.</data>
  <data key="d3">chunk-4356d14be0458851058bcbfa4dd8eff9</data>
  <data key="d4">نظام_التجارة_الإلكترونية</data>
  <data key="d5">1776814638</data>
  <data key="d6"></data>
</node>
<node id="Ninety Days">
  <data key="d0">Ninety Days</data>
  <data key="d1">data</data>
  <data key="d2">Ninety Days is the specific time duration within which the Minister must issue the Regulation.&lt;SEP&gt;A time period of ninety days required to pass before the system becomes effective.</data>
  <data key="d3">chunk-3323a5605fc02cf6b08e6daf15866451&lt;SEP&gt;chunk-f1cdab301d132fa946f551f1fb83be2d</data>
  <data key="d4">نظام_التجارة_الإلكترونية</data>
  <data key="d5">1776814646</data>
  <data key="d6"></data>
</node>
<node id="Article Twenty-Six">
  <data key="d0">Article Twenty-Six</data>
  <data key="d1">content</data>
  <data key="d2">Article Twenty-Six is a legal provision that establishes the effective date of a specific regulation.</data>
  <data key="d3">chunk-f1cdab301d132fa946f551f1fb83be2d</data>
  <data key="d4">نظام_التجارة_الإلكترونية</data>
  <data key="d5">1776814646</data>
  <data key="d6"></data>
</node>
<edge source="Consumer Protection System" target="Competent Authority">
  <data key="d7">1.0</data>
  <data key="d8">The Competent Authority is responsible for implementing and supervising the Consumer Protection System.</data>
  <data key="d9">implementation,supervision</data>
  <data key="d10">chunk-7a8154749b1feccbfe768628b4e18b60</data>
  <data key="d11">مشروع_نظام_حماية_المستهلك</data>
  <data key="d12">1776813787</data>
  <data key="d13"></data>
</edge>
<edge source="Consumer Protection System" target="Executive Regulations">
  <data key="d7">1.0</data>
  <data key="d8">The Executive Regulations provide the detailed implementation rules for the overarching Consumer Protection System.</data>
  <data key="d9">implementation,legal hierarchy</data>
  <data key="d10">chunk-7a8154749b1feccbfe768628b4e18b60</data>
  <data key="d11">مشروع_نظام_حماية_المستهلك</data>
  <data key="d12">1776813787</data>
  <data key="d13"></data>
</edge>
<edge source="Consumer Protection System" target="Corrective Measures">
  <data key="d7">1.0</data>
  <data key="d8">Corrective Measures are the specific actions taken to ensure compliance with and address violations of the Consumer Protection System.</data>
  <data key="d9">compliance,enforcement</data>
  <data key="d10">chunk-7a8154749b1feccbfe768628b4e18b60</data>
  <data key="d11">مشروع_نظام_حماية_المستهلك</data>
  <data key="d12">1776813787</data>
  <data key="d13"></data>
</edge>
<edge source="Consumer Protection System" target="Economic Operator">
  <data key="d7">1.0</data>
  <data key="d8">The system aims to achieve a fair balance of rights and obligations between the Economic Operator and the Consumer.</data>
  <data key="d9">balance of rights,regulatory relationship</data>
  <data key="d10">chunk-5921e285b202ad77baf19401a767f275</data>
  <data key="d11">مشروع_نظام_حماية_المستهلك</data>
  <data key="d12">1776813795</data>
  <data key="d13"></data>
</edge>
<edge source="Consumer Protection System" target="Consumer">
  <data key="d7">1.0</data>
  <data key="d8">The system protects the Consumer from harm and ensures their rights are upheld against the Economic Operator.</data>
  <data key="d9">protection,regulatory relationship</data>
  <data key="d10">chunk-5921e285b202ad77baf19401a767f275</data>
  <data key="d11">مشروع_نظام_حماية_المستهلك</data>
  <data key="d12">1776813795</data>
  <data key="d13"></data>
</edge>
<edge source="Consumer Protection System" target="Harmful Or Defective Products">
  <data key="d7">1.0</data>
