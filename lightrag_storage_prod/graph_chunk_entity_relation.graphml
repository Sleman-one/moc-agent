  <data key="d13"></data>
</edge>
<edge source="Consumer" target="Assembly Instructions">
  <data key="d7">1.0</data>
  <data key="d8">The consumer relies on the economic operator's assembly instructions when installing the product.</data>
  <data key="d9">dependency,reliance</data>
  <data key="d10">chunk-5b3ef01cc61802e9c5898cf34fea5a1c</data>
