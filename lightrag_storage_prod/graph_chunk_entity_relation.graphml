<edge source="Contract" target="Article 31">
  <data key="d7">1.0</data>
  <data key="d8">Article 31 regulates contracts by prohibiting specific unfair terms between the Economic Operator and the Consumer.</data>
  <data key="d9">legal regulation,prohibition</data>
