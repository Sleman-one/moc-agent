</edge>
<edge source="Administrative Court" target="Diwan Al-Muzalim">
  <data key="d7">1.0</data>
  <data key="d8">The Administrative Court operates within or is part of the Diwan Al-Muzalim structure.</data>
  <data key="d9">affiliation,institutional structure</data>
