  <data key="d10">chunk-e2e9d4353bb95f7bca809f541cd54320</data>
  <data key="d11">مشروع_نظام_حماية_المستهلك</data>
  <data key="d12">1776814304</data>
  <data key="d13"></data>
</edge>
<edge source="Consumer" target="Damage Compensation">
  <data key="d7">1.0</data>
  <data key="d8">The Consumer is entitled to Damage Compensation for losses incurred.</data>
  <data key="d9">remedy,restitution</data>
