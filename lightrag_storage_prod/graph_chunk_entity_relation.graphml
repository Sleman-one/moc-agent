</edge>
<edge source="Article Thirty-Five" target="Contract Outside Business Premises">
  <data key="d7">1.0</data>
  <data key="d8">Article Thirty-Five defines and regulates contracts considered to be signed outside the business premises.</data>
  <data key="d9">legal definition,regulation</data>
