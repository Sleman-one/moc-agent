  <data key="d13"></data>
</edge>
<edge source="Article 31" target="Dispute Resolution Clause">
  <data key="d7">1.0</data>
  <data key="d8">Article 31 explicitly prohibits clauses that exclude or limit the Consumer's right to access judicial authorities.</data>
  <data key="d9">legal prohibition,unfair term</data>
