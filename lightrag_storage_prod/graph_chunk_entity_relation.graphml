  <data key="d13"></data>
</edge>
<edge source="Consumer" target="Product Assembly Error">
  <data key="d7">1.0</data>
  <data key="d8">The consumer is not liable for assembly errors if they resulted from incorrect instructions provided by the economic operator.</data>
  <data key="d9">causation,liability exemption</data>
