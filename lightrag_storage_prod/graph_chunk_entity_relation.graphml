  <data key="d12">1776814128</data>
  <data key="d13"></data>
</edge>
<edge source="Consumer" target="Payment Methods Information">
  <data key="d7">1.0</data>
  <data key="d8">The Consumer must receive detailed information about payment methods to understand financial obligations.</data>
  <data key="d9">financial transparency,transaction details</data>
  <data key="d10">chunk-a4d1807f1fc70cd86f3926044c5b150a</data>
  <data key="d11">مشروع_نظام_حماية_المستهلك</data>
  <data key="d12">1776814128</data>
  <data key="d13"></data>
</edge>
<edge source="Consumer" target="Contract Formation Commitment">
  <data key="d7">1.0</data>
  <data key="d8">If the Economic Operator fails to disclose this commitment, the contract is not binding on the Consumer.</data>
  <data key="d9">binding effect,informed consent</data>
  <data key="d10">chunk-a4d1807f1fc70cd86f3926044c5b150a</data>
  <data key="d11">مشروع_نظام_حماية_المستهلك</data>
  <data key="d12">1776814128</data>
  <data key="d13"></data>
</edge>
<edge source="Consumer" target="Article Forty-Five">
  <data key="d7">1.0</data>
  <data key="d8">Article Forty-Five grants the Consumer the right to modify their remote order.</data>
  <data key="d9">entitlement,legal right</data>
  <data key="d10">chunk-bbcbc9c6d4024ed107a3aed8073f87c9</data>
  <data key="d11">مشروع_نظام_حماية_المستهلك</data>
  <data key="d12">1776814133</data>
  <data key="d13"></data>
</edge>
<edge source="Consumer" target="Remote Contract Agreement">
  <data key="d7">1.0</data>
  <data key="d8">The Consumer enters into the Remote Contract Agreement, which activates the modification rights.</data>
  <data key="d9">participation,transaction initiation</data>
  <data key="d10">chunk-bbcbc9c6d4024ed107a3aed8073f87c9</data>
  <data key="d11">مشروع_نظام_حماية_المستهلك</data>
  <data key="d12">1776814133</data>
  <data key="d13"></data>
</edge>
<edge source="Consumer" target="Twenty-Four Hour Period">
  <data key="d7">1.0</data>
  <data key="d8">The Consumer must exercise their right to modify the order within the Twenty-Four Hour Period following consent.</data>
  <data key="d9">modification window,time constraint</data>
  <data key="d10">chunk-bbcbc9c6d4024ed107a3aed8073f87c9</data>
