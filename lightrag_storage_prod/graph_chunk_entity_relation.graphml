  <data key="d12">1776814581</data>
  <data key="d13"></data>
</edge>
<edge source="Consumer" target="Article 56">
  <data key="d7">1.0</data>
  <data key="d8">Article 56 ensures the Consumer receives necessary information regarding service and part availability.</data>
  <data key="d9">consumer protection,information rights</data>
  <data key="d10">chunk-0bb91dbf0d0d74be15a1f23f7ef09d39</data>
  <data key="d11">مشروع_نظام_حماية_المستهلك</data>
  <data key="d12">1776814222</data>
  <data key="d13"></data>
</edge>
<edge source="Consumer" target="Article Sixty-Five">
  <data key="d7">1.0</data>
  <data key="d8">Article Sixty-Five grants specific rights and remedies to the Consumer when they suffer harm.</data>
