</edge>
<edge source="Article 31" target="Liability Exemption">
  <data key="d7">1.0</data>
  <data key="d8">Article 31 explicitly prohibits clauses that exempt the Economic Operator from liability for fault or negligence.</data>
  <data key="d9">legal prohibition,unfair term</data>
