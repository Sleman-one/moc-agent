  <data key="d12">1776814208</data>
  <data key="d13"></data>
</edge>
<edge source="Consumer" target="Refund Amounts">
  <data key="d7">1.0</data>
  <data key="d8">The Consumer receives the Refund Amounts back from the Economic Operator as part of the contract termination process.</data>
  <data key="d9">financial receipt,restitution</data>
  <data key="d10">chunk-019c5b0704e7195269616af2f7e331e2</data>
