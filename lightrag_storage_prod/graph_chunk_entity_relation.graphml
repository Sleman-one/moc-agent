  <data key="d12">1776814100</data>
  <data key="d13"></data>
</edge>
<edge source="Consumer" target="Right To Cancel Contract">
  <data key="d7">1.0</data>
  <data key="d8">The Consumer possesses the legal Right To Cancel Contract but may waive it through explicit consent in certain scenarios.</data>
  <data key="d9">legal entitlement,waiver</data>
  <data key="d10">chunk-bc991839dd0cc98acaf12ea5bc58ecc8</data>
