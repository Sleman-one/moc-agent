  <data key="d11">مشروع_نظام_حماية_المستهلك</data>
  <data key="d12">1776814020</data>
  <data key="d13"></data>
</edge>
<edge source="Article 31" target="Unilateral Modification Right">
  <data key="d7">1.0</data>
  <data key="d8">Article 31 explicitly prohibits clauses granting the Economic Operator unilateral power to modify or cancel contracts.</data>
  <data key="d9">legal prohibition,unfair term</data>
  <data key="d10">chunk-6e82925b2fc83bb4036c3b1f007ba923</data>
