<edge source="Article Forty" target="Off-Premises Contracts">
  <data key="d7">1.0</data>
  <data key="d8">Article Forty establishes that the general rules for Off-Premises Contracts do not apply in specific cases.</data>
  <data key="d9">legal exclusion,regulatory scope</data>
  <data key="d10">chunk-0931bf17be9284d5fcf4f6332cd19598</data>
