  <data key="d12">1776814118</data>
  <data key="d13"></data>
</edge>
<edge source="Consumer" target="Right of Withdrawal">
  <data key="d7">1.0</data>
  <data key="d8">The Consumer possesses the right to withdraw from the contract within the period defined in Article Forty-One.</data>
