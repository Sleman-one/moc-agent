  <data key="d0">Seventeenth Article</data>
  <data key="d1">content</data>
  <data key="d2">A specific legal article whose violation triggers penalties under Article Ninety-Seven.</data>
  <data key="d3">chunk-0f17c98aec4af855d06847e8dc54f39d</data>
  <data key="d4">مشروع_نظام_حماية_المستهلك</data>
  <data key="d5">1776814438</data>
  <data key="d6"></data>
</node>
