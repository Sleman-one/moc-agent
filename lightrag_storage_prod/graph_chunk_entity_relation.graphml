  <data key="d13"></data>
</edge>
<edge source="Contract Outside Business Premises" target="Visit Outside Premises">
  <data key="d7">1.0</data>
  <data key="d8">The contract is classified as outside business premises if it is concluded during such visits, unless requested by the consumer.</data>
  <data key="d9">circumstance,conditional trigger</data>
  <data key="d10">chunk-23ea8c91412652822b5737482cd0f932</data>
  <data key="d11">مشروع_نظام_حماية_المستهلك</data>
