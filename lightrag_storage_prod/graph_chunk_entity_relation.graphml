</edge>
<edge source="Consumer" target="Communication Technology">
  <data key="d7">1.0</data>
  <data key="d8">The Consumer relies on Communication Technology for transmission; if it prevents error correction, specific rights apply.</data>
  <data key="d9">dependency,limitation</data>
  <data key="d10">chunk-ef5c3f67882b7588927d8bca42047269</data>
  <data key="d11">نظام_التجارة_الإلكترونية</data>
  <data key="d12">1776814501</data>
  <data key="d13"></data>
</edge>
<edge source="Consumer" target="Service Provider">
  <data key="d7">4.0</data>
  <data key="d8">The Consumer must notify the Service Provider of errors via an Error Correction Notice within a specified timeframe.&lt;SEP&gt;The Service Provider holds a legal responsibility to protect the Consumer's personal data and privacy while handling their electronic communications.&lt;SEP&gt;The Service Provider issues an invoice to the Consumer following the conclusion of their contract.&lt;SEP&gt;The Consumer and Service Provider are parties to a contract where the Service Provider delivers goods or services.</data>
  <data key="d9">contractual obligation,contractual relationship,data stewardship,delivery,legal obligation,notification,remedy,transactional relationship</data>
  <data key="d10">chunk-ef5c3f67882b7588927d8bca42047269&lt;SEP&gt;chunk-30e605d9deb7e33ed48fcf51264fb16e&lt;SEP&gt;chunk-ed4385a57314892c443871db0108ea1b&lt;SEP&gt;chunk-c0d47d22075e87911525f2b1b1a29585</data>
  <data key="d11">نظام_التجارة_الإلكترونية</data>
  <data key="d12">1776814581</data>
  <data key="d13"></data>
</edge>
<edge source="Consumer" target="Error Correction Notice">
  <data key="d7">1.0</data>
  <data key="d8">The Consumer submits an Error Correction Notice to rectify errors in electronic correspondence.</data>
  <data key="d9">rectification,submission</data>
  <data key="d10">chunk-ef5c3f67882b7588927d8bca42047269</data>
  <data key="d11">نظام_التجارة_الإلكترونية</data>
  <data key="d12">1776814501</data>
  <data key="d13"></data>
</edge>
<edge source="Consumer" target="Personal Data">
  <data key="d7">1.0</data>
  <data key="d8">The Consumer has the right to privacy regarding their Personal Data, requiring the Service Provider to obtain consent for any non-standard usage.</data>
  <data key="d9">ownership,privacy right</data>
  <data key="d10">chunk-30e605d9deb7e33ed48fcf51264fb16e</data>
  <data key="d11">نظام_التجارة_الإلكترونية</data>
  <data key="d12">1776814508</data>
  <data key="d13"></data>
</edge>
<edge source="Consumer" target="Electronic Communications">
  <data key="d7">1.0</data>
  <data key="d8">The Consumer maintains privacy rights over their Electronic Communications, limiting how the Service Provider can utilize this information.</data>
  <data key="d9">ownership,privacy right</data>
  <data key="d10">chunk-30e605d9deb7e33ed48fcf51264fb16e</data>
  <data key="d11">نظام_التجارة_الإلكترونية</data>
  <data key="d12">1776814508</data>
  <data key="d13"></data>
</edge>
<edge source="Consumer" target="Article 5">
  <data key="d7">1.0</data>
  <data key="d8">The Consumer benefits from the protections mandated by Article 5, which limits the Service Provider's ability to use or disclose personal data without consent.</data>
  <data key="d9">legal right,protection</data>
  <data key="d10">chunk-30e605d9deb7e33ed48fcf51264fb16e</data>
  <data key="d11">نظام_التجارة_الإلكترونية</data>
  <data key="d12">1776814509</data>
  <data key="d13"></data>
</edge>
<edge source="Consumer" target="Contract Statement">
  <data key="d7">1.0</data>
  <data key="d8">The Contract Statement is directed towards the Consumer to ensure transparency of the contract terms.</data>
  <data key="d9">receipt,target audience</data>
  <data key="d10">chunk-b0f30d8785ebf55f768a527b1ede688f</data>
  <data key="d11">نظام_التجارة_الإلكترونية</data>
  <data key="d12">1776814526</data>
  <data key="d13"></data>
</edge>
<edge source="Consumer" target="Article Eight">
  <data key="d7">1.0</data>
  <data key="d8">Article Eight defines the Consumer as the intended recipient of the mandatory invoice information.</data>
  <data key="d9">legal right,recipient protection</data>
  <data key="d10">chunk-ed4385a57314892c443871db0108ea1b</data>
  <data key="d11">نظام_التجارة_الإلكترونية</data>
  <data key="d12">1776814533</data>
  <data key="d13"></data>
</edge>
<edge source="Consumer" target="False Representation">
  <data key="d7">1.0</data>
  <data key="d8">False Representations are designed to directly or indirectly deceive or mislead Consumers.</data>
  <data key="d9">deception,harm</data>
  <data key="d10">chunk-7dce39ad69ab952b0a24c9573b89731d</data>
  <data key="d11">نظام_التجارة_الإلكترونية</data>
  <data key="d12">1776814549</data>
  <data key="d13"></data>
</edge>
<edge source="Consumer" target="Product Delivery Date">
  <data key="d7">1.0</data>
  <data key="d8">The Product Delivery Date initiates the Seven-Day Period for consumers who receive physical goods.</data>
  <data key="d9">temporal reference,trigger event</data>
  <data key="d10">chunk-98520f83d72a9bac06aacc6991d7d823</data>
  <data key="d11">نظام_التجارة_الإلكترونية</data>
  <data key="d12">1776814570</data>
  <data key="d13"></data>
</edge>
<edge source="Consumer" target="Contracting Date">
  <data key="d7">1.0</data>
  <data key="d8">The Contracting Date initiates the Seven-Day Period for consumers who only contract for services without receiving a tangible product.</data>
  <data key="d9">temporal reference,trigger event</data>
  <data key="d10">chunk-98520f83d72a9bac06aacc6991d7d823</data>
  <data key="d11">نظام_التجارة_الإلكترونية</data>
  <data key="d12">1776814570</data>
  <data key="d13"></data>
</edge>
<edge source="Consumer" target="Custom-Produced Products">
  <data key="d7">1.0</data>
  <data key="d8">The Consumer loses the right to withdraw from contracts involving Custom-Produced Products unless they contain defects.</data>
  <data key="d9">exception,exclusion</data>
  <data key="d10">chunk-98520f83d72a9bac06aacc6991d7d823</data>
  <data key="d11">نظام_التجارة_الإلكترونية</data>
  <data key="d12">1776814571</data>
  <data key="d13"></data>
</edge>
<edge source="Consumer" target="Used Media And Software">
  <data key="d7">1.0</data>
  <data key="d8">The Consumer cannot withdraw from contracts involving Used Media And Software once they have been used.</data>
  <data key="d9">exception,exclusion</data>
  <data key="d10">chunk-98520f83d72a9bac06aacc6991d7d823</data>
  <data key="d11">نظام_التجارة_الإلكترونية</data>
  <data key="d12">1776814571</data>
  <data key="d13"></data>
</edge>
<edge source="Consumer" target="Periodicals">
  <data key="d7">1.0</data>
  <data key="d8">The Consumer is not allowed to withdraw from contracts concerning Periodicals.</data>
  <data key="d9">exception,exclusion</data>
  <data key="d10">chunk-98520f83d72a9bac06aacc6991d7d823</data>
  <data key="d11">نظام_التجارة_الإلكترونية</data>
  <data key="d12">1776814571</data>
  <data key="d13"></data>
</edge>
<edge source="Consumer" target="Service Providers">
  <data key="d7">1.0</data>
  <data key="d8">The Consumer cannot withdraw from contracts with Service Providers offering accommodation, transport, or catering.</data>
  <data key="d9">exception,exclusion</data>
  <data key="d10">chunk-98520f83d72a9bac06aacc6991d7d823</data>
  <data key="d11">نظام_التجارة_الإلكترونية</data>
  <data key="d12">1776814571</data>
  <data key="d13"></data>
</edge>
<edge source="Consumer" target="Online Downloaded Products">
  <data key="d7">1.0</data>
  <data key="d8">The Consumer generally cannot withdraw from Online Downloaded Products, except if there are defects preventing download or compliance issues.</data>
  <data key="d9">exception,exclusion</data>
  <data key="d10">chunk-98520f83d72a9bac06aacc6991d7d823</data>
  <data key="d11">نظام_التجارة_الإلكترونية</data>
  <data key="d12">1776814571</data>
  <data key="d13"></data>
</edge>
<edge source="Consumer" target="Defects">
  <data key="d7">1.0</data>
  <data key="d8">The existence of Defects preserves the Consumer's right to withdraw from contracts that would otherwise be exempt (e.g., custom goods, media).</data>
  <data key="d9">exception preservation,quality issue</data>
  <data key="d10">chunk-98520f83d72a9bac06aacc6991d7d823</data>
  <data key="d11">نظام_التجارة_الإلكترونية</data>
  <data key="d12">1776814571</data>
  <data key="d13"></data>
</edge>
<edge source="Consumer" target="Article 13">
  <data key="d7">1.0</data>
  <data key="d8">Article 13 provides the legal framework governing the Consumer's right of withdrawal.</data>
  <data key="d9">legal basis,regulation</data>
  <data key="d10">chunk-98520f83d72a9bac06aacc6991d7d823</data>
  <data key="d11">نظام_التجارة_الإلكترونية</data>
  <data key="d12">1776814571</data>
  <data key="d13"></data>
</edge>
<edge source="Consumer" target="Costs">
  <data key="d7">1.0</data>
  <data key="d8">The Consumer bears costs associated with contract withdrawal if they derive benefit from the service or product before withdrawing.</data>
  <data key="d9">financial responsibility,penalty</data>
  <data key="d10">chunk-98520f83d72a9bac06aacc6991d7d823</data>
  <data key="d11">نظام_التجارة_الإلكترونية</data>
  <data key="d12">1776814571</data>
  <data key="d13"></data>
</edge>
<edge source="Consumer" target="Regulations">
  <data key="d7">1.0</data>
  <data key="d8">Regulations define further exceptions to the rights outlined in Article 13 based on product or service nature.</data>
  <data key="d9">definition,legal hierarchy</data>
  <data key="d10">chunk-98520f83d72a9bac06aacc6991d7d823</data>
  <data key="d11">نظام_التجارة_الإلكترونية</data>
  <data key="d12">1776814571</data>
  <data key="d13"></data>
</edge>
<edge source="Consumer" target="Fifteen-Day Period">
  <data key="d7">1.0</data>
  <data key="d8">The Consumer can exercise the right to void the contract if the delay exceeds the Fifteen-Day Period.</data>
  <data key="d9">termination right,time limit</data>
  <data key="d10">chunk-c0d47d22075e87911525f2b1b1a29585</data>
  <data key="d11">نظام_التجارة_الإلكترونية</data>
  <data key="d12">1776814581</data>
  <data key="d13"></data>
</edge>
<edge source="Consumer" target="Delay Costs">
  <data key="d7">1.0</data>
  <data key="d8">The Consumer is entitled to recover Delay Costs associated with the Service Provider's breach of delivery timelines.</data>
  <data key="d9">compensation,financial loss</data>
  <data key="d10">chunk-c0d47d22075e87911525f2b1b1a29585</data>
  <data key="d11">نظام_التجارة_الإلكترونية</data>
  <data key="d12">1776814581</data>
  <data key="d13"></data>
</edge>
<edge source="Economic Operator" target="Service Provider">
  <data key="d7">1.0</data>
  <data key="d8">A Service Provider is classified as a type of Economic Operator.</data>
  <data key="d9">classification</data>
  <data key="d10">chunk-7a8154749b1feccbfe768628b4e18b60</data>
  <data key="d11">مشروع_نظام_حماية_المستهلك</data>
  <data key="d12">1776813787</data>
  <data key="d13"></data>
</edge>
<edge source="Economic Operator" target="Advertisement">
  <data key="d7">1.0</data>
  <data key="d8">Economic Operators use Advertisement to promote their products and enhance their market reputation.</data>
  <data key="d9">marketing,promotion</data>
  <data key="d10">chunk-7a8154749b1feccbfe768628b4e18b60</data>
  <data key="d11">مشروع_نظام_حماية_المستهلك</data>
  <data key="d12">1776813787</data>
  <data key="d13"></data>
</edge>
<edge source="Economic Operator" target="Establishment">
  <data key="d7">2.0</data>
  <data key="d8">Economic Operators conduct their business activities at Establishments.&lt;SEP&gt;An Economic Operator operates from an Establishment, which is linked to their official Address.</data>
  <data key="d9">location,operation,registration</data>
  <data key="d10">chunk-7a8154749b1feccbfe768628b4e18b60</data>
  <data key="d11">مشروع_نظام_حماية_المستهلك</data>
  <data key="d12">1776813787</data>
  <data key="d13"></data>
</edge>
<edge source="Economic Operator" target="Address">
  <data key="d7">1.0</data>
  <data key="d8">The Address is a registered identifier for the Economic Operator in commercial or national registries.</data>
  <data key="d9">identification,registration</data>
  <data key="d10">chunk-7a8154749b1feccbfe768628b4e18b60</data>
  <data key="d11">مشروع_نظام_حماية_المستهلك</data>
  <data key="d12">1776813788</data>
  <data key="d13"></data>
</edge>
<edge source="Economic Operator" target="Article 3 Application Scope">
  <data key="d7">1.0</data>
  <data key="d8">Article 3 defines the scope of the system, which applies to the relationship involving the Economic Operator.</data>
  <data key="d9">regulatory scope,subject definition</data>
  <data key="d10">chunk-23f16ba22036bb88da1664b390f68ca1</data>
  <data key="d11">مشروع_نظام_حماية_المستهلك</data>
  <data key="d12">1776813802</data>
  <data key="d13"></data>
</edge>
<edge source="Economic Operator" target="Remote Contract">
  <data key="d7">1.0</data>
  <data key="d8">The Economic Operator is the other party to the Remote Contract with the Consumer.</data>
  <data key="d9">contractual party,counterparty</data>
  <data key="d10">chunk-23f16ba22036bb88da1664b390f68ca1</data>
  <data key="d11">مشروع_نظام_حماية_المستهلك</data>
  <data key="d12">1776813802</data>
  <data key="d13"></data>
</edge>
<edge source="Economic Operator" target="Vulnerable Consumer">
  <data key="d7">1.0</data>
  <data key="d8">Economic Operators must pay special attention to Vulnerable Consumers if they are aware of the consumer's condition or if the job nature dictates it.</data>
  <data key="d9">business obligation,consumer welfare</data>
  <data key="d10">chunk-19ba78abd7c521789ac7c4a38d25114e</data>
  <data key="d11">مشروع_نظام_حماية_المستهلك</data>
  <data key="d12">1776813820</data>
  <data key="d13"></data>
</edge>
<edge source="Economic Operator" target="Article Five">
  <data key="d7">1.0</data>
  <data key="d8">Article Five outlines the obligations of Economic Operators towards vulnerable consumers.</data>
  <data key="d9">regulatory scope</data>
  <data key="d10">chunk-19ba78abd7c521789ac7c4a38d25114e</data>
  <data key="d11">مشروع_نظام_حماية_المستهلك</data>
  <data key="d12">1776813821</data>
  <data key="d13"></data>
</edge>
<edge source="Economic Operator" target="Article Six">
  <data key="d7">1.0</data>
  <data key="d8">Article Six imposes the legal obligation on the Economic Operator to disclose specific information.</data>
  <data key="d9">legal obligation,mandate</data>
  <data key="d10">chunk-dbb3cd60b4bd30c2e1383463af5924c9</data>
  <data key="d11">مشروع_نظام_حماية_المستهلك</data>
  <data key="d12">1776813836</data>
  <data key="d13"></data>
</edge>
<edge source="Economic Operator" target="Manufacturer">
  <data key="d7">1.0</data>
  <data key="d8">The Economic Operator may need to identify the Manufacturer if they are not the direct seller.</data>
  <data key="d9">identification,supply chain</data>
  <data key="d10">chunk-dbb3cd60b4bd30c2e1383463af5924c9</data>
  <data key="d11">مشروع_نظام_حماية_المستهلك</data>
  <data key="d12">1776813836</data>
  <data key="d13"></data>
</edge>
<edge source="Economic Operator" target="Importer">
  <data key="d7">1.0</data>
  <data key="d8">The Economic Operator may need to identify the Importer if they are not the direct seller.</data>
  <data key="d9">identification,supply chain</data>
  <data key="d10">chunk-dbb3cd60b4bd30c2e1383463af5924c9</data>
  <data key="d11">مشروع_نظام_حماية_المستهلك</data>
  <data key="d12">1776813836</data>
  <data key="d13"></data>
</edge>
<edge source="Economic Operator" target="Distributor">
  <data key="d7">1.0</data>
  <data key="d8">The Economic Operator may need to identify the Distributor if they are not the direct seller.</data>
  <data key="d9">identification,supply chain</data>
  <data key="d10">chunk-dbb3cd60b4bd30c2e1383463af5924c9</data>
  <data key="d11">مشروع_نظام_حماية_المستهلك</data>
  <data key="d12">1776813837</data>
  <data key="d13"></data>
</edge>
<edge source="Economic Operator" target="Agent">
  <data key="d7">1.0</data>
  <data key="d8">The Economic Operator may need to identify the Agent if they are not the direct seller.</data>
  <data key="d9">identification,supply chain</data>
  <data key="d10">chunk-dbb3cd60b4bd30c2e1383463af5924c9</data>
  <data key="d11">مشروع_نظام_حماية_المستهلك</data>
  <data key="d12">1776813837</data>
  <data key="d13"></data>
</edge>
<edge source="Economic Operator" target="Business Identity Data">
  <data key="d7">1.0</data>
  <data key="d8">The Economic Operator is responsible for disclosing Business Identity Data, which may include their own details or those of the manufacturer/importer.</data>
  <data key="d9">identity provision,responsibility</data>
  <data key="d10">chunk-dbb3cd60b4bd30c2e1383463af5924c9</data>
  <data key="d11">مشروع_نظام_حماية_المستهلك</data>
  <data key="d12">1776813837</data>
  <data key="d13"></data>
</edge>
<edge source="Economic Operator" target="Article Nine">
  <data key="d7">1.0</data>
  <data key="d8">Article Nine imposes obligations specifically on the Economic Operator regarding price transparency.</data>
  <data key="d9">regulatory obligation,subject definition</data>
  <data key="d10">chunk-bea1774b99d54deb70d6648484455df9</data>
  <data key="d11">مشروع_نظام_حماية_المستهلك</data>
  <data key="d12">1776813851</data>
  <data key="d13"></data>
</edge>
<edge source="Economic Operator" target="Product Price">
  <data key="d7">1.0</data>
  <data key="d8">The Economic Operator is required to declare the Product Price to the consumer.</data>
  <data key="d9">disclosure duty,pricing information</data>
  <data key="d10">chunk-bea1774b99d54deb70d6648484455df9</data>
  <data key="d11">مشروع_نظام_حماية_المستهلك</data>
  <data key="d12">1776813852</data>
  <data key="d13"></data>
</edge>
<edge source="Economic Operator" target="Product">
  <data key="d7">7.0</data>
  <data key="d8">The Economic Operator must ensure the Product displays the price clearly or prominently.&lt;SEP&gt;Economic Operators are forbidden from making false claims about Product availability, limiting product lifecycles without justification, or using deceptive editorial content to promote Products.&lt;SEP&gt;Economic Operators must not use restrictive phrases like "no returns or exchanges" on their documents, ads, or premises.&lt;SEP&gt;The Economic Operator is responsible for delivering the Product to the Consumer.&lt;SEP&gt;The Economic Operator may withhold the refund until it receives the Product or proof of its return by the Consumer.&lt;SEP&gt;The Economic Operator may withhold refund until receipt of the Product or proof of its return by the Consumer.&lt;SEP&gt;The Economic Operator must repair, replace, or refund the Product in case of a statutory warranty breach.</data>
  <data key="d9">advertising,delivery obligation,label placement,labeling,obligation,pricing requirement,receipt,receipt condition,refund dependency,remediation,returns,truthfulness,verification</data>
  <data key="d10">chunk-bea1774b99d54deb70d6648484455df9&lt;SEP&gt;chunk-811c2282e5faf0e8745c51115a8604e5&lt;SEP&gt;chunk-dfe11211e281ef2abb48c30415b14f61&lt;SEP&gt;chunk-93b8a69d3470d8fd4caae59080df0a54&lt;SEP&gt;chunk-019c5b0704e7195269616af2f7e331e2&lt;SEP&gt;chunk-4f2ea9e729aab0deda37682e004b3fc6</data>
  <data key="d11">مشروع_نظام_حماية_المستهلك</data>
  <data key="d12">1776814202</data>
  <data key="d13"></data>
</edge>
<edge source="Economic Operator" target="Price Offer">
  <data key="d7">1.0</data>
  <data key="d8">The Price Offer is free unless the Economic Operator informs the consumer of a cost before preparing it.</data>
  <data key="d9">conditional fee,cost liability</data>
  <data key="d10">chunk-757265b902decbf8c55e1b070565644a</data>
  <data key="d11">مشروع_نظام_حماية_المستهلك</data>
  <data key="d12">1776813858</data>
  <data key="d13"></data>
</edge>
<edge source="Economic Operator" target="Article Twelve">
  <data key="d7">1.0</data>
  <data key="d8">Article Twelve imposes a prohibition on the Economic Operator regarding the display of prices.</data>
  <data key="d9">legal obligation,prohibition</data>
  <data key="d10">chunk-eba8035888adcd130040e9dbfd9a13d6</data>
  <data key="d11">مشروع_نظام_حماية_المستهلك</data>
  <data key="d12">1776813871</data>
  <data key="d13"></data>
</edge>
<edge source="Economic Operator" target="Unintentional Error">
  <data key="d7">1.0</data>
  <data key="d8">The Economic Operator is exempt from penalties if the Price Discrepancy is caused by Unintentional Error.</data>
  <data key="d9">cause,liability exemption</data>
  <data key="d10">chunk-eba8035888adcd130040e9dbfd9a13d6</data>
  <data key="d11">مشروع_نظام_حماية_المستهلك</data>
  <data key="d12">1776813871</data>
  <data key="d13"></data>
</edge>
<edge source="Economic Operator" target="Products Or Services">
  <data key="d7">1.0</data>
  <data key="d8">The Economic Operator offers Products or Services and is required to display a single price for identical items.</data>
