</edge>
<edge source="Consumer" target="Alternative Dispute Resolution Providers">
  <data key="d7">1.0</data>
  <data key="d8">Providers are required to disclose information about the Consumer's waiver right, and the binding and enforceable nature of results to the Consumer/Public.</data>
  <data key="d9">disclosure,transparency</data>
  <data key="d10">chunk-8eba08bab139116de9ee95fe214a7f7e</data>
