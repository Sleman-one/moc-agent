  <data key="d12">1776814110</data>
  <data key="d13"></data>
</edge>
<edge source="Consumer" target="Service Contracts">
  <data key="d7">1.0</data>
  <data key="d8">Consumers cannot cancel Service Contracts if they have agreed to immediate execution knowing it waives cancellation rights.</data>
  <data key="d9">contractual restriction,execution condition</data>
  <data key="d10">chunk-bc991839dd0cc98acaf12ea5bc58ecc8</data>
  <data key="d11">مشروع_نظام_حماية_المستهلك</data>
  <data key="d12">1776814110</data>
  <data key="d13"></data>
</edge>
<edge source="Consumer" target="Digital Content">
  <data key="d7">1.0</data>
  <data key="d8">The Consumer's right to cancel Digital Content is restricted once execution begins with explicit acknowledgment.</data>
  <data key="d9">conditional access,digital rights</data>
  <data key="d10">chunk-bc991839dd0cc98acaf12ea5bc58ecc8</data>
  <data key="d11">مشروع_نظام_حماية_المستهلك</data>
  <data key="d12">1776814110</data>
  <data key="d13"></data>
</edge>
<edge source="Consumer" target="Periodical Publications">
  <data key="d7">1.0</data>
  <data key="d8">The Consumer is generally exempt from the right to cancel contracts involving Periodical Publications.</data>
  <data key="d9">exemption,publication type</data>
  <data key="d10">chunk-bc991839dd0cc98acaf12ea5bc58ecc8</data>
  <data key="d11">مشروع_نظام_حماية_المستهلك</data>
  <data key="d12">1776814110</data>
  <data key="d13"></data>
</edge>
<edge source="Consumer" target="Software Programs">
  <data key="d7">1.0</data>
  <data key="d8">The Consumer loses the right to cancel Software Programs if they were opened after delivery.</data>
  <data key="d9">post-delivery status,product integrity</data>
  <data key="d10">chunk-bc991839dd0cc98acaf12ea5bc58ecc8</data>
  <data key="d11">مشروع_نظام_حماية_المستهلك</data>
  <data key="d12">1776814110</data>
  <data key="d13"></data>
</edge>
<edge source="Consumer" target="Accommodation And Transport Services">
  <data key="d7">1.0</data>
  <data key="d8">The Consumer cannot cancel Accommodation And Transport Services if the contract specifies a fixed date or duration.</data>
  <data key="d9">scheduling,time-bound services</data>
  <data key="d10">chunk-bc991839dd0cc98acaf12ea5bc58ecc8</data>
  <data key="d11">مشروع_نظام_حماية_المستهلك</data>
  <data key="d12">1776814110</data>
  <data key="d13"></data>
</edge>
<edge source="Consumer" target="Statutory Warranty">
  <data key="d7">2.0</data>
  <data key="d8">The Statutory Warranty referenced in Article 49 provides the legal framework for verifying the product's condition during the return period.&lt;SEP&gt;The Consumer holds inherent rights under the Statutory Warranty that are not compromised by the acceptance of an Additional Warranty.</data>
  <data key="d9">entitlement,legal basis,protection,verification</data>
  <data key="d10">chunk-019c5b0704e7195269616af2f7e331e2&lt;SEP&gt;chunk-bbdc0bdfb37532b71f5f2a12cb9f8fe0</data>
