  <data key="d11">مشروع_نظام_حماية_المستهلك</data>
  <data key="d12">1776813917</data>
  <data key="d13"></data>
</edge>
<edge source="Economic Operator" target="Deceptive Advertising">
  <data key="d7">1.0</data>
  <data key="d8">Economic Operators are prohibited from engaging in deceptive advertising, including false claims about availability and undisclosed sponsored content.</data>
  <data key="d9">prohibition,transparency</data>
  <data key="d10">chunk-811c2282e5faf0e8745c51115a8604e5</data>
  <data key="d11">مشروع_نظام_حماية_المستهلك</data>
  <data key="d12">1776813917</data>
  <data key="d13"></data>
</edge>
<edge source="Economic Operator" target="Product Lifecycle Manipulation">
  <data key="d7">1.0</data>
