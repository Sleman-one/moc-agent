  <data key="d5">1776814367</data>
  <data key="d6"></data>
</node>
<node id="Ministry Of Justice">
  <data key="d0">Ministry Of Justice</data>
  <data key="d1">organization</data>
  <data key="d2">The government ministry that receives activity reports from ADR providers and platforms.&lt;SEP&gt;The Ministry of Justice collaborates with the Competent Authority to establish procedures for consumer representation in lawsuits.</data>
