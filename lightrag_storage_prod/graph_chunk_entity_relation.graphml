  <data key="d11">مشروع_نظام_حماية_المستهلك</data>
  <data key="d12">1776814195</data>
  <data key="d13"></data>
</edge>
<edge source="Consumer" target="Product Or Service">
  <data key="d7">2.0</data>
  <data key="d8">The Product or Service is delivered to the Consumer for use.&lt;SEP&gt;The Consumer has the right to recover payments made for the Product Or Service if the contract is voided due to excessive delay.</data>
  <data key="d9">contractual object,delivery,refund right,usage</data>
  <data key="d10">chunk-d15616980ad303389944137db1af4f22&lt;SEP&gt;chunk-c0d47d22075e87911525f2b1b1a29585</data>
