  <data key="d13"></data>
</edge>
<edge source="Visit Outside Premises" target="Consumer Residence">
  <data key="d7">1.0</data>
  <data key="d8">A visit to the consumer's residence is one scenario defining the contract as outside business premises.</data>
  <data key="d9">context,location type</data>
  <data key="d10">chunk-23ea8c91412652822b5737482cd0f932</data>
  <data key="d11">مشروع_نظام_حماية_المستهلك</data>
